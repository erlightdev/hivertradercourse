{
  "$schema": "https://opencode.ai/config.json",
	"mcp": {
		"better-t-stack": {
			"type": "local",
			"command": ["npx", "create-better-t-stack@latest", "mcp"],
			"enabled": true,
			"environment": {}
		},
		"context7": {
			"type": "local",
			"command": ["npx", "-y", "@upstash/context7-mcp"],
			"enabled": true,
			"environment": {}
		},
		"astro-docs": {
			"type": "remote",
			"url": "https://mcp.docs.astro.build/mcp",
			"enabled": true
		},
		"better-auth": {
			"type": "remote",
			"url": "https://mcp.inkeep.com/better-auth/mcp",
			"enabled": true
		}
	}
}
