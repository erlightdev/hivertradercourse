{
	"name": "@hivertradercourse/db",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"db:push": "prisma db push --schema=prisma/schema",
		"db:generate": "prisma generate --schema=prisma/schema",
		"db:migrate": "prisma migrate dev --schema=prisma/schema",
		"postinstall": "prisma generate --schema=prisma/schema",
		"db:studio": "prisma studio",
		"db:start": "node docker-compose.js compose up -d",
		"db:watch": "node docker-compose.js compose up",
		"db:stop": "node docker-compose.js compose stop",
		"db:down": "node docker-compose.js compose down"
	},
	"dependencies": {
		"@hivertradercourse/env": "*",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"dotenv": "^17.2.2",
		"pg": "^8.17.1",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@hivertradercourse/config": "*",
		"@types/pg": "^8.16.0",
		"prisma": "^7.8.0",
		"typescript": "^6"
	}
}
