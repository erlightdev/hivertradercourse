---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/dashboard/Sidebar.astro";
import BlogPanel from "../components/blog/BlogPanel.astro";
import Topbar from "../components/dashboard/Topbar.astro";
import CommandDialog from "../components/dashboard/CommandDialog.astro";
import CreateCourseModal from "../components/dashboard/CreateCourseModal.astro";
import CoursesView from "../components/courses/CoursesView.astro";
import AnalyticsView from "../components/analytics/AnalyticsView.astro";
import ProjectsView from "../components/projects/ProjectsView.astro";
import LiveSessionView from "../components/live-session/LiveSessionView.astro";
import ChatView from "../components/chat/ChatView.astro";
import BlogPostsView from "../components/blog/BlogPostsView.astro";
import BlogEditorView from "../components/blog/BlogEditorView.astro";
import SeoSheet from "../components/blog/SeoSheet.astro";
import BlogCategoriesView from "../components/blog/BlogCategoriesView.astro";
import BlogTagsView from "../components/blog/BlogTagsView.astro";
---

<Layout title="Dashboard - Hiver" hideHeader={true}>
  <!-- Main Dashboard Wrapper -->
  <div id="dashboard-root" class="hidden h-screen w-screen flex bg-background text-foreground overflow-hidden font-sans select-none antialiased">
    
    <Sidebar />

    <BlogPanel />

    <!-- RIGHT CONTENT AREA -->
    <div class="flex-1 flex flex-col overflow-hidden h-full">
      
      <Topbar />

      <!-- EMPTY DASHBOARD CANVAS -->
      <main class="flex-1 overflow-y-auto p-6 md:p-8 bg-muted/10">
        
        <!-- Dashboard Header (Title only) -->
        <div class="flex items-center justify-between border-b border-border/40 pb-4">
          <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-foreground" id="dashboard-title">Dashboard</h1>
        </div>

        <!-- Default Dashboard View -->
        <div id="view-default" class="mt-6">
        </div>

        <CoursesView />

        <AnalyticsView />

        <ProjectsView />

        <LiveSessionView />

        <ChatView />

        <BlogPostsView />

        <BlogEditorView />

        <BlogCategoriesView />

        <BlogTagsView />

      </main>
    </div>

  </div>

  <!-- Loading State Panel -->
  <div id="dashboard-loading" class="flex h-screen w-screen bg-background items-center justify-center">
    <div class="text-center space-y-3">
      <div class="w-10 h-10 border-4 border-primary border-t-transparent rounded-full animate-spin mx-auto"></div>
      <p class="text-sm font-medium text-muted-foreground">Securing secure Shadcn workspace...</p>
    </div>
  </div>

  <!-- Redirection Panel -->
  <div id="dashboard-redirect" class="hidden flex h-screen w-screen bg-background items-center justify-center">
    <p class="text-sm font-semibold text-muted-foreground">Access denied. Redirecting to login...</p>
  </div>

  <!-- Sonner-style Toaster Container -->
  <div id="toaster-container" class="fixed bottom-4 right-4 z-[110] flex flex-col gap-2 max-w-sm w-full pointer-events-none"></div>

  <!-- Shadcn-style Custom Dialog Overlay (AlertDialog) -->
  <div id="custom-dialog-overlay" class="fixed inset-0 bg-background/85 backdrop-blur-xs z-[105] hidden items-center justify-center animate-fade-in">
    <div id="custom-dialog-content" class="bg-card border border-border rounded-sm shadow-lg max-w-md w-full p-6 space-y-4 scale-95 opacity-0 transition-all duration-200">
      <div class="space-y-1.5">
        <h3 id="custom-dialog-title" class="text-sm font-bold text-foreground">Confirm Action</h3>
        <p id="custom-dialog-description" class="text-xs text-muted-foreground leading-relaxed"></p>
      </div>
      <div id="custom-dialog-input-container" class="hidden space-y-1.5">
        <input type="text" id="custom-dialog-input" class="w-full px-3 py-2 text-xs bg-card border border-border rounded-sm focus:ring-1 focus:ring-primary focus:outline-hidden text-foreground font-medium" />
      </div>
      <div class="flex items-center justify-end gap-2 pt-2">
        <button id="custom-dialog-cancel" class="px-4 py-2 hover:bg-muted text-xs font-bold rounded-sm border border-border transition-colors cursor-pointer text-muted-foreground hover:text-foreground">
          Cancel
        </button>
        <button id="custom-dialog-confirm" class="px-4 py-2 bg-primary text-primary-foreground hover:bg-primary/95 text-xs font-bold rounded-sm transition-colors cursor-pointer shadow-sm">
          Confirm
        </button>
      </div>
    </div>
  </div>

  <CommandDialog />

  <CreateCourseModal />

  <SeoSheet />
</Layout>

<!-- Core Styles Overrides -->
<style>
  /* Sidebar collapsing CSS states */
  #sidebar.collapsed {
    width: 64px;
  }
  #sidebar.collapsed .sidebar-text {
    display: none;
  }
  #sidebar.collapsed .sidebar-item {
    justify-content: center;
    padding-left: 0;
    padding-right: 0;
  }
  #sidebar.collapsed #unlock-card {
    display: none;
  }
  #sidebar.collapsed #profile-block-btn {
    justify-content: center;
  }
  #sidebar.collapsed #profile-block-btn svg {
    display: none;
  }

  /* Command Dialog Styling */
  .command-item[aria-selected="true"] {
    background-color: var(--muted) !important;
    color: var(--foreground) !important;
  }

  /* Tiptap editor placeholder & prose styling */
  .ProseMirror p.is-editor-empty:first-child::before {
    content: attr(data-placeholder);
    float: left;
    color: var(--muted-foreground);
    opacity: 0.6;
    pointer-events: none;
    height: 0;
  }
  .ProseMirror {
    outline: none;
    min-height: 320px;
  }
  .ProseMirror h1 {
    font-size: 1.5rem;
    font-weight: 800;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }
  .ProseMirror h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 0.875rem;
    margin-bottom: 0.4rem;
  }
  .ProseMirror h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 0.75rem;
    margin-bottom: 0.3rem;
  }
  .ProseMirror ul {
    list-style-type: disc;
    padding-left: 1.25rem;
    margin-bottom: 0.5rem;
  }
  .ProseMirror ol {
    list-style-type: decimal;
    padding-left: 1.25rem;
    margin-bottom: 0.5rem;
  }
  .ProseMirror blockquote {
    border-left: 3px solid var(--primary);
    padding-left: 1rem;
    color: var(--muted-foreground);
    font-style: italic;
    margin: 1rem 0;
  }
  .ProseMirror pre {
    background: var(--muted);
    padding: 0.75rem 1rem;
    border-radius: 0.125rem;
    font-family: monospace;
    font-size: 0.85rem;
    margin: 1rem 0;
    overflow-x: auto;
  }
  .ProseMirror code {
    background: var(--muted);
    padding: 0.15rem 0.3rem;
    border-radius: 0.125rem;
    font-family: monospace;
    font-size: 0.85rem;
  }
  .ProseMirror a {
    color: var(--primary);
    text-decoration: underline;
    cursor: pointer;
  }
  .ProseMirror img {
    border-radius: 0.125rem;
    max-height: 300px;
    object-fit: cover;
    margin: 1rem 0;
  }
</style>

<!-- Client State Script -->
<script>
  import { authClient } from "../lib/auth-client";
  import { PUBLIC_SERVER_URL } from "astro:env/client";
  import { Editor, Extension } from "@tiptap/core";
  import StarterKit from "@tiptap/starter-kit";
  import Image from "@tiptap/extension-image";
  import { Placeholder } from "@tiptap/extensions";
  import BubbleMenu from "@tiptap/extension-bubble-menu";
  import DragHandle from "@tiptap/extension-drag-handle";
  import Highlight from "@tiptap/extension-highlight";
  import TextAlign from "@tiptap/extension-text-align";
  import Subscript from "@tiptap/extension-subscript";
  import Superscript from "@tiptap/extension-superscript";
  import Suggestion from "@tiptap/suggestion";
  import { blogStore, toast, dialog } from "../lib/dashboard-store";

  // Expose store and utils globally
  (window as any).blogStore = blogStore;
  (window as any).toast = toast;
  (window as any).dialog = dialog;
  (window as any).showView = showView;

  // Selectors
  const root = document.getElementById("dashboard-root")!;
  const loading = document.getElementById("dashboard-loading")!;
  const redirect = document.getElementById("dashboard-redirect")!;
  
  // Sidebar items
  const sidebar = document.getElementById("sidebar")!;
  const outerToggle = document.getElementById("sidebar-collapse-toggle-outer")!;
  const blogBtn = document.getElementById("blog-submenu-btn")!;
  const blogPanel = document.getElementById("blog-panel")!;
  const blogCloseBtn = document.getElementById("blog-panel-close")!;
  const blogArrow = document.getElementById("blog-arrow")!;
  
  // Command Dialog Elements
  const searchTrigger = document.getElementById("navbar-search")!;
  const commandOverlay = document.getElementById("command-dialog-overlay")!;
  const commandContent = document.getElementById("command-dialog-content")!;
  const commandSearch = document.getElementById("command-search-input") as HTMLInputElement;
  const commandItems = document.querySelectorAll(".command-item") as NodeListOf<HTMLButtonElement>;
  const commandGroups = document.querySelectorAll(".command-group") as NodeListOf<HTMLElement>;
  const noResults = document.getElementById("command-no-results")!;
  
  // Profile dropdown toggles
  const profileBtn = document.getElementById("profile-block-btn")!;
  const profileDropup = document.getElementById("profile-dropup-menu")!;
  const logoutBtn = document.getElementById("menu-logout-btn")!;
  
  // User profile values
  const profileName = document.getElementById("profile-name")!;
  const profileEmail = document.getElementById("profile-email")!;
  const menuUserName = document.getElementById("menu-user-name")!;
  const menuUserEmail = document.getElementById("menu-user-email")!;
  const avatarFallback = document.getElementById("avatar-fallback")!;
  const topAvatarFallback = document.getElementById("top-avatar-fallback")!;
  const topDropdownAvatarFallback = document.getElementById("top-dropdown-avatar-fallback")!;

  // Top Avatar Profile toggles
  const topAvatarBtn = document.getElementById("top-user-avatar-btn")!;
  const topProfileDropdown = document.getElementById("top-profile-dropdown")!;
  const topLogoutBtn = document.getElementById("top-logout-btn")!;
  const topProfileName = document.getElementById("top-profile-name")!;
  const topProfileEmail = document.getElementById("top-profile-email")!;

  // Theme Toggler
  const themeToggleBtn = document.getElementById("theme-toggle")!;
  const sunIcon = document.getElementById("theme-toggle-sun")!;
  const moonIcon = document.getElementById("theme-toggle-moon")!;

  // Invite & Earn & Notifications selectors
  const inviteBtn = document.getElementById("invite-earn-btn")!;
  const inviteDropdown = document.getElementById("invite-earn-dropdown")!;
  const copyReferralBtn = document.getElementById("copy-referral-btn")!;
  const referralLinkInput = document.getElementById("referral-link-input") as HTMLInputElement;
  const copyToast = document.getElementById("copy-toast")!;
  
  const notificationsBellBtn = document.getElementById("notifications-bell-btn")!;
  const notificationsDropdown = document.getElementById("notifications-dropdown")!;
  const bellUnreadDot = document.getElementById("bell-unread-dot")!;
  const markAllReadBtn = document.getElementById("mark-all-read-btn")!;

  // Connect selectors
  const connectBtn = document.getElementById("connect-btn")!;
  const connectDropdown = document.getElementById("connect-dropdown")!;
  const connectArrow = document.getElementById("connect-arrow")!;

  // Create Course Selectors
  const createCourseBtn = document.getElementById("create-course-btn")!;
  const createCourseModalOverlay = document.getElementById("create-course-modal-overlay")!;
  const createCourseModalContent = document.getElementById("create-course-modal-content")!;
  const closeCreateCourseBtn = document.getElementById("close-create-course-btn")!;
  const cancelCreateCourseBtn = document.getElementById("cancel-create-course-btn")!;
  const createCourseForm = document.getElementById("create-course-form") as HTMLFormElement;

  // Blog views control
  const views = [
    "view-default",
    "view-courses",
    "view-analytics",
    "view-projects",
    "view-live-session",
    "view-chat",
    "view-blog-posts",
    "view-blog-editor",
    "view-blog-categories",
    "view-blog-tags"
  ];

  function showView(viewId: string) {
    views.forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        if (id === viewId) {
          el.classList.remove("hidden");
        } else {
          el.classList.add("hidden");
        }
      }
    });
  }

  function openBlogPanel() {
    blogPanel.classList.remove("w-0", "border-border/0");
    blogPanel.classList.add("w-56", "border-border");
    blogArrow.classList.add("rotate-180");
    
    // Check if the primary sidebar is collapsed before opening secondary panel so we can restore it on close
    if (sidebar.classList.contains("collapsed")) {
      localStorage.setItem("sidebar-was-collapsed-before-blog", "true");
      sidebar.classList.remove("collapsed");
      localStorage.setItem("sidebar-collapsed", "false");
    } else {
      localStorage.setItem("sidebar-was-collapsed-before-blog", "false");
    }
    localStorage.setItem("blog-panel-open", "true");
  }

  function closeBlogPanel() {
    blogPanel.classList.remove("w-56", "border-border");
    blogPanel.classList.add("w-0", "border-border/0");
    blogArrow.classList.remove("rotate-180");
    localStorage.setItem("blog-panel-open", "false");

    // Restore the primary sidebar's collapsed icon state if it was originally collapsed
    const wasCollapsedBefore = localStorage.getItem("sidebar-was-collapsed-before-blog") === "true";
    if (wasCollapsedBefore) {
      sidebar.classList.add("collapsed");
      localStorage.setItem("sidebar-collapsed", "true");
    }
    localStorage.removeItem("sidebar-was-collapsed-before-blog");
  }

  // Tiptap editor variables
  let editor: Editor | null = null;
  let currentHoverPos: number | null = null;

  // Slash-command block menu items
  const ICONS = {
    h1: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h8"/><path d="M4 18V6"/><path d="M12 18V6"/><path d="m17 12 3-2v8"/></svg>',
    h2: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h8"/><path d="M4 18V6"/><path d="M12 18V6"/><path d="M21 18h-4c0-4 4-3 4-6 0-1.5-2-2.5-4-1"/></svg>',
    h3: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h8"/><path d="M4 18V6"/><path d="M12 18V6"/><path d="M17.5 10.5c1.7-1 3.5 0 3.5 1.5a2 2 0 0 1-2 2"/><path d="M17 17.5c2 1.5 4 .3 4-1.5a2 2 0 0 0-2-2"/></svg>',
    bullet: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" x2="21" y1="6" y2="6"/><line x1="8" x2="21" y1="12" y2="12"/><line x1="8" x2="21" y1="18" y2="18"/><line x1="3" x2="3.01" y1="6" y2="6"/><line x1="3" x2="3.01" y1="12" y2="12"/><line x1="3" x2="3.01" y1="18" y2="18"/></svg>',
    ordered: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="10" x2="21" y1="6" y2="6"/><line x1="10" x2="21" y1="12" y2="12"/><line x1="10" x2="21" y1="18" y2="18"/><path d="M4 6h1v4"/><path d="M4 10h2"/><path d="M6 18H4c0-1 2-2 2-3s-1-1.5-2-1"/></svg>',
    quote: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 6H3"/><path d="M21 12H8"/><path d="M21 18H8"/><path d="M3 12v6"/></svg>',
    code: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
    divider: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="12" y2="12"/></svg>',
    image: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>',
  };

  const slashItems = [
    { title: "Heading 1", desc: "Big section heading", icon: ICONS.h1, command: ({ editor, range }: any) => editor.chain().focus().deleteRange(range).setNode("heading", { level: 1 }).run() },
    { title: "Heading 2", desc: "Medium section heading", icon: ICONS.h2, command: ({ editor, range }: any) => editor.chain().focus().deleteRange(range).setNode("heading", { level: 2 }).run() },
    { title: "Heading 3", desc: "Small section heading", icon: ICONS.h3, command: ({ editor, range }: any) => editor.chain().focus().deleteRange(range).setNode("heading", { level: 3 }).run() },
    { title: "Bullet List", desc: "Simple bulleted list", icon: ICONS.bullet, command: ({ editor, range }: any) => editor.chain().focus().deleteRange(range).toggleBulletList().run() },
    { title: "Numbered List", desc: "Ordered list", icon: ICONS.ordered, command: ({ editor, range }: any) => editor.chain().focus().deleteRange(range).toggleOrderedList().run() },
    { title: "Quote", desc: "Capture a quotation", icon: ICONS.quote, command: ({ editor, range }: any) => editor.chain().focus().deleteRange(range).toggleBlockquote().run() },
    { title: "Code Block", desc: "Code snippet with syntax", icon: ICONS.code, command: ({ editor, range }: any) => editor.chain().focus().deleteRange(range).toggleCodeBlock().run() },
    { title: "Divider", desc: "Horizontal rule", icon: ICONS.divider, command: ({ editor, range }: any) => editor.chain().focus().deleteRange(range).setHorizontalRule().run() },
    { title: "Image", desc: "Embed an image by URL", icon: ICONS.image, command: async ({ editor, range }: any) => {
        editor.chain().focus().deleteRange(range).run();
        const url = await dialog.prompt("Insert Image", "Enter the image source URL:");
        if (url) editor.chain().focus().setImage({ src: url }).run();
      } },
  ];

  // Slash command extension (vanilla suggestion-based)
  const SlashCommand = Extension.create<{ suggestion: Record<string, any> }>({
    name: "slashCommand",
    addOptions() {
      return {
        suggestion: {
          char: "/",
          command: ({ editor, range, props }: any) => props.command({ editor, range }),
        },
      };
    },
    addProseMirrorPlugins() {
      return [Suggestion({ editor: this.editor, ...this.options.suggestion })];
    },
  });

  function buildSlashRender() {
    let popup: HTMLElement | null = null;
    let items: any[] = [];
    let selected = 0;
    let activeProps: any = null;

    const draw = () => {
      if (!popup) return;
      popup.innerHTML = "";
      if (items.length === 0) {
        const empty = document.createElement("div");
        empty.className = "slash-empty";
        empty.textContent = "No matching blocks";
        popup.appendChild(empty);
        return;
      }
      items.forEach((item, i) => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "slash-item" + (i === selected ? " is-selected" : "");
        btn.innerHTML = `<span class="slash-item-icon">${item.icon}</span><span class="slash-item-text"><span class="slash-item-title">${item.title}</span><span class="slash-item-desc">${item.desc}</span></span>`;
        btn.addEventListener("mousedown", (e) => { e.preventDefault(); pick(i); });
        btn.addEventListener("mouseenter", () => { selected = i; mark(); });
        popup!.appendChild(btn);
      });
    };

    const mark = () => {
      popup?.querySelectorAll(".slash-item").forEach((el, i) => el.classList.toggle("is-selected", i === selected));
    };

    const pick = (i: number) => {
      const item = items[i];
      if (item && activeProps) activeProps.command(item);
    };

    const place = (props: any) => {
      if (!popup) return;
      const rect = props.clientRect?.();
      if (!rect) return;
      const menuW = 280;
      const left = Math.min(rect.left, window.innerWidth - menuW - 16);
      popup.style.left = `${Math.max(8, left)}px`;
      popup.style.top = `${rect.bottom + 6}px`;
    };

    return {
      onStart: (props: any) => {
        activeProps = props;
        items = props.items;
        selected = 0;
        popup = document.createElement("div");
        popup.className = "slash-menu";
        document.body.appendChild(popup);
        draw();
        place(props);
      },
      onUpdate: (props: any) => {
        activeProps = props;
        items = props.items;
        selected = 0;
        draw();
        place(props);
      },
      onKeyDown: (props: any) => {
        const key = props.event.key;
        if (key === "ArrowDown") { selected = (selected + 1) % Math.max(items.length, 1); mark(); return true; }
        if (key === "ArrowUp") { selected = (selected - 1 + items.length) % Math.max(items.length, 1); mark(); return true; }
        if (key === "Enter") { pick(selected); return true; }
        if (key === "Escape") { popup?.remove(); popup = null; return true; }
        return false;
      },
      onExit: () => { popup?.remove(); popup = null; },
    };
  }

  // Open the slash block menu below the hovered block (used by + buttons)
  function openBlockMenuAtHover() {
    if (!editor) return;
    if (currentHoverPos == null) {
      editor.chain().focus().insertContent("/").run();
      return;
    }
    const node = editor.state.doc.nodeAt(currentHoverPos);
    const after = currentHoverPos + (node ? node.nodeSize : 1);
    editor.chain().focus().insertContentAt(after, { type: "paragraph" }).setTextSelection(after + 1).insertContent("/").run();
  }

  function initTiptap() {
    if (editor) return;

    editor = new Editor({
      element: document.getElementById("editor-content-tiptap")!,
      extensions: [
        StarterKit.configure({
          link: {
            openOnClick: false,
            HTMLAttributes: {
              class: "text-primary underline underline-offset-2 cursor-pointer",
            },
          },
        }),
        Highlight.configure({
          HTMLAttributes: { class: "rounded px-0.5" },
        }),
        TextAlign.configure({
          types: ["heading", "paragraph"],
        }),
        Subscript,
        Superscript,
        Image.configure({
          HTMLAttributes: {
            class: "rounded-lg max-h-[360px] object-cover my-4",
          },
        }),
        Placeholder.configure({
          placeholder: ({ node }: any) =>
            node.type.name === "heading" ? "Heading" : "Write something, or press '/' for blocks…",
        }),
        BubbleMenu.configure({
          element: document.getElementById("editor-bubble-menu")!,
          options: { placement: "top", offset: 8 },
        }),
        DragHandle.configure({
          render: () => {
            const wrapper = document.createElement("div");
            wrapper.className = "drag-handle-wrapper";

            const plus = document.createElement("button");
            plus.type = "button";
            plus.className = "drag-handle-plus";
            plus.title = "Add block below";
            plus.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>';
            plus.addEventListener("mousedown", (e) => e.preventDefault());
            plus.addEventListener("click", (e) => { e.preventDefault(); e.stopPropagation(); openBlockMenuAtHover(); });

            const grip = document.createElement("div");
            grip.className = "drag-handle-grip";
            grip.title = "Drag to move";
            grip.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="5" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="9" cy="19" r="1"/><circle cx="15" cy="5" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="19" r="1"/></svg>';

            wrapper.appendChild(plus);
            wrapper.appendChild(grip);
            return wrapper;
          },
          onNodeChange: ({ pos }: any) => {
            currentHoverPos = typeof pos === "number" ? pos : null;
          },
        }),
        SlashCommand.configure({
          suggestion: {
            char: "/",
            command: ({ editor, range, props }: any) => props.command({ editor, range }),
            items: ({ query }: any) =>
              slashItems.filter((i) => i.title.toLowerCase().includes((query || "").toLowerCase())),
            render: buildSlashRender,
          },
        }),
      ],
      editorProps: {
        attributes: {
          class: "tiptap-editor focus:outline-hidden min-h-[340px] px-1 py-1 prose prose-base dark:prose-invert max-w-none",
        },
      },
    });

    // Share editor instance globally
    (window as any).editor = editor;

    // Top toolbar button clicks
    const toolbar = document.getElementById("editor-toolbar")!;
    toolbar.querySelectorAll("button").forEach(btn => {
      btn.addEventListener("click", async (e) => {
        e.preventDefault();
        if (!editor) return;
        await runEditorCommand(btn.getAttribute("data-cmd"));
        updateToolbarStates();
      });
    });

    // Bubble menu button clicks
    const bubble = document.getElementById("editor-bubble-menu")!;
    bubble.querySelectorAll("button").forEach(btn => {
      btn.addEventListener("mousedown", (e) => e.preventDefault());
      btn.addEventListener("click", async (e) => {
        e.preventDefault();
        if (!editor) return;
        await runEditorCommand(btn.getAttribute("data-bubble"));
        updateToolbarStates();
      });
    });

    editor.on("selectionUpdate", updateToolbarStates);
    editor.on("transaction", updateToolbarStates);
  }

  // Share initTiptap globally
  (window as any).initTiptap = initTiptap;

  async function runEditorCommand(cmd: string | null) {
    if (!editor || !cmd) return;
    if (cmd === "bold") editor.chain().focus().toggleBold().run();
    else if (cmd === "italic") editor.chain().focus().toggleItalic().run();
    else if (cmd === "underline") editor.chain().focus().toggleUnderline().run();
    else if (cmd === "strike") editor.chain().focus().toggleStrike().run();
    else if (cmd === "code") editor.chain().focus().toggleCode().run();
    else if (cmd === "highlight") editor.chain().focus().toggleHighlight().run();
    else if (cmd === "superscript") editor.chain().focus().toggleSuperscript().run();
    else if (cmd === "subscript") editor.chain().focus().toggleSubscript().run();
    else if (cmd === "h1") editor.chain().focus().toggleHeading({ level: 1 }).run();
    else if (cmd === "h2") editor.chain().focus().toggleHeading({ level: 2 }).run();
    else if (cmd === "h3") editor.chain().focus().toggleHeading({ level: 3 }).run();
    else if (cmd === "bulletList") editor.chain().focus().toggleBulletList().run();
    else if (cmd === "orderedList") editor.chain().focus().toggleOrderedList().run();
    else if (cmd === "blockquote") editor.chain().focus().toggleBlockquote().run();
    else if (cmd === "codeBlock") editor.chain().focus().toggleCodeBlock().run();
    else if (cmd === "alignLeft") editor.chain().focus().setTextAlign("left").run();
    else if (cmd === "alignCenter") editor.chain().focus().setTextAlign("center").run();
    else if (cmd === "alignRight") editor.chain().focus().setTextAlign("right").run();
    else if (cmd === "alignJustify") editor.chain().focus().setTextAlign("justify").run();
    else if (cmd === "undo") editor.chain().focus().undo().run();
    else if (cmd === "redo") editor.chain().focus().redo().run();
    else if (cmd === "slash") editor.chain().focus().insertContent("/").run();
    else if (cmd === "link") {
      const url = await dialog.prompt("Add Link", "Enter the destination URL:");
      if (url) editor.chain().focus().extendMarkRange("link").setLink({ href: url }).run();
      else if (url === "") editor.chain().focus().extendMarkRange("link").unsetLink().run();
    } else if (cmd === "image") {
      const url = await dialog.prompt("Insert Image", "Enter the image source URL:");
      if (url) editor.chain().focus().setImage({ src: url }).run();
    }
  }

  function updateToolbarStates() {
    const ed = editor;
    if (!ed) return;
    const stateMap: Record<string, () => boolean> = {
      bold: () => ed.isActive("bold"),
      italic: () => ed.isActive("italic"),
      underline: () => ed.isActive("underline"),
      strike: () => ed.isActive("strike"),
      code: () => ed.isActive("code"),
      highlight: () => ed.isActive("highlight"),
      superscript: () => ed.isActive("superscript"),
      subscript: () => ed.isActive("subscript"),
      h1: () => ed.isActive("heading", { level: 1 }),
      h2: () => ed.isActive("heading", { level: 2 }),
      h3: () => ed.isActive("heading", { level: 3 }),
      bulletList: () => ed.isActive("bulletList"),
      orderedList: () => ed.isActive("orderedList"),
      blockquote: () => ed.isActive("blockquote"),
      codeBlock: () => ed.isActive("codeBlock"),
      link: () => ed.isActive("link"),
      alignLeft: () => ed.isActive({ textAlign: "left" }),
      alignCenter: () => ed.isActive({ textAlign: "center" }),
      alignRight: () => ed.isActive({ textAlign: "right" }),
      alignJustify: () => ed.isActive({ textAlign: "justify" }),
    };

    const apply = (el: Element, cmd: string | null) => {
      if (!cmd) return;
      const fn = stateMap[cmd];
      if (!fn) return; 
      const active = fn();
      if (active) {
        el.classList.add("bg-muted", "text-foreground");
        el.classList.remove("text-muted-foreground");
      } else {
        el.classList.remove("bg-muted", "text-foreground");
        el.classList.add("text-muted-foreground");
      }
    };

    document.getElementById("editor-toolbar")?.querySelectorAll("button").forEach(btn => apply(btn, btn.getAttribute("data-cmd")));
    document.getElementById("editor-bubble-menu")?.querySelectorAll("button").forEach(btn => apply(btn, btn.getAttribute("data-bubble")));
  }

  async function init() {
    let retries = 0;
    const maxRetries = 5;

    async function checkSession() {
      try {
        const { data: session } = await authClient.getSession();
        
        if (!session?.user) {
          loading.classList.add("hidden");
          redirect.classList.remove("hidden");
          window.location.href = "/login";
          return;
        }

        const currentUser = session.user;
        (window as any).currentUser = currentUser;

        // Populate user info (using logged-in details, fallback to Hiver)
        const uName = currentUser.name || "Hiver";
        const uEmail = currentUser.email || "admin@hiver.com.np";
        const uInitials = uName.split(" ").map((n: string) => n[0]).join("").toUpperCase();

        profileName.textContent = uName;
        profileEmail.textContent = uEmail;
        menuUserName.textContent = uName;
        menuUserEmail.textContent = uEmail;
        avatarFallback.textContent = uInitials;
        topAvatarFallback.textContent = uInitials;
        topDropdownAvatarFallback.textContent = uInitials;

        // Populate top profile details
        topProfileName.textContent = uName;
        topProfileEmail.textContent = uEmail;

        // Populate referral link dynamically
        if (referralLinkInput) {
          const userCode = uName.split(" ")[0].toUpperCase();
          referralLinkInput.value = `https://hiverlms.com/invite/${userCode}250`;
        }

        // Setup Event Listeners
        setupListeners();
        updateThemeIcons();

        // Restore sidebar collapsed state
        const sidebarCollapsed = localStorage.getItem("sidebar-collapsed") === "true";
        if (sidebarCollapsed) {
          sidebar.classList.add("collapsed");
        } else {
          sidebar.classList.remove("collapsed");
        }

        // Restore active navigation item and blog panel state
        const activeNavItemId = localStorage.getItem("active-nav-item") || "nav-dashboard";
        const blogPanelOpen = localStorage.getItem("blog-panel-open") === "true";

        if (activeNavItemId) {
          const activeNavItem = document.getElementById(activeNavItemId);
          if (activeNavItem) {
            if (activeNavItem.classList.contains("sidebar-submenu-item")) {
              if (blogPanelOpen && !sidebarCollapsed) {
                openBlogPanel();
              }
              activeNavItem.click();
            } else {
              activeNavItem.click();
            }
          } else {
            showView("view-default");
          }
        } else {
          showView("view-default");
        }

        loading.classList.add("hidden");
        root.classList.remove("hidden");
      } catch (error) {
        console.warn("Session check failed, server might be restarting:", error);
        
        if (retries < maxRetries) {
          retries++;
          const loadingText = loading.querySelector("p");
          if (loadingText) {
            loadingText.textContent = `Server connection lost. Reconnecting (Attempt ${retries}/${maxRetries})...`;
          }
          setTimeout(checkSession, 1500);
        } else {
          loading.classList.add("hidden");
          redirect.classList.remove("hidden");
          window.location.href = "/login";
        }
      }
    }

    checkSession();
  }

  let activeIndex = 0;

  function updateSelection(visibleItems: HTMLButtonElement[], index: number) {
    visibleItems.forEach((item, i) => {
      if (i === index) {
        item.setAttribute("aria-selected", "true");
        item.scrollIntoView({ block: "nearest" });
      } else {
        item.removeAttribute("aria-selected");
      }
    });
    activeIndex = index;
  }

  function filterCommands(query: string) {
    const q = query.toLowerCase().trim();

    if (q === "") {
      commandItems.forEach(item => {
        item.classList.add("hidden");
        item.removeAttribute("aria-selected");
      });
      commandGroups.forEach(group => {
        group.classList.add("hidden");
      });
      noResults.classList.add("hidden");
      activeIndex = 0;
      return;
    }

    const visibleItems: HTMLButtonElement[] = [];

    // Filter items
    commandItems.forEach(item => {
      const text = item.textContent?.toLowerCase() || "";
      const matches = text.includes(q);
      if (matches) {
        item.classList.remove("hidden");
        visibleItems.push(item);
      } else {
        item.classList.add("hidden");
        item.removeAttribute("aria-selected");
      }
    });

    // Show/hide groups based on visible children
    commandGroups.forEach(group => {
      const groupItems = group.querySelectorAll(".command-item:not(.hidden)");
      if (groupItems.length === 0) {
        group.classList.add("hidden");
      } else {
        group.classList.remove("hidden");
      }
    });

    // Show/hide no results text
    if (visibleItems.length === 0) {
      noResults.classList.remove("hidden");
    } else {
      noResults.classList.add("hidden");
    }

    // Set initial selection to first visible item
    if (visibleItems.length > 0) {
      updateSelection(visibleItems, 0);
    } else {
      activeIndex = 0;
    }
  }

  function setupListeners() {
    // 1. Sidebar collapse toggle
    const toggleSidebar = () => {
      const isCollapsed = sidebar.classList.toggle("collapsed");
      localStorage.setItem("sidebar-collapsed", isCollapsed ? "true" : "false");
      if (isCollapsed) {
        closeBlogPanel();
      }
    };
    outerToggle.addEventListener("click", toggleSidebar);

    // 2. Command Dialog toggles
    const openCommand = () => {
      commandOverlay.classList.remove("hidden");
      commandOverlay.classList.add("flex");
      void commandOverlay.offsetWidth; // Force reflow
      commandContent.classList.remove("scale-95", "opacity-0");
      commandContent.classList.add("scale-100", "opacity-100");
      commandSearch.value = "";
      filterCommands("");
      commandSearch.focus();
    };

    const closeCommand = () => {
      commandContent.classList.remove("scale-100", "opacity-100");
      commandContent.classList.add("scale-95", "opacity-0");
      setTimeout(() => {
        commandOverlay.classList.add("hidden");
        commandOverlay.classList.remove("flex");
      }, 200);
    };

    searchTrigger.addEventListener("click", openCommand);
    
    commandOverlay.addEventListener("click", (e) => {
      if (e.target === commandOverlay) {
        closeCommand();
      }
    });

    // Create Course Modal toggles
    const openCreateCourse = () => {
      createCourseModalOverlay.classList.remove("hidden");
      createCourseModalOverlay.classList.add("flex");
      
      // Close other dropdowns
      inviteDropdown.classList.add("hidden");
      notificationsDropdown.classList.add("hidden");
      topProfileDropdown.classList.add("hidden");
      connectDropdown.classList.add("hidden");
      connectArrow.classList.remove("rotate-180");
      
      void createCourseModalOverlay.offsetWidth; // Force reflow
      createCourseModalContent.classList.remove("scale-95", "opacity-0");
      createCourseModalContent.classList.add("scale-100", "opacity-100");
    };

    const closeCreateCourse = () => {
      createCourseModalContent.classList.remove("scale-100", "opacity-100");
      createCourseModalContent.classList.add("scale-95", "opacity-0");
      setTimeout(() => {
        createCourseModalOverlay.classList.add("hidden");
        createCourseModalOverlay.classList.remove("flex");
      }, 200);
    };

    if (createCourseBtn) {
      createCourseBtn.addEventListener("click", openCreateCourse);
    }
    if (closeCreateCourseBtn) {
      closeCreateCourseBtn.addEventListener("click", closeCreateCourse);
    }
    if (cancelCreateCourseBtn) {
      cancelCreateCourseBtn.addEventListener("click", closeCreateCourse);
    }
    createCourseModalOverlay.addEventListener("click", (e) => {
      if (e.target === createCourseModalOverlay) {
        closeCreateCourse();
      }
    });

    if (createCourseForm) {
      createCourseForm.addEventListener("submit", (e) => {
        e.preventDefault();
        const title = (document.getElementById("course-title") as HTMLInputElement).value;
        const category = (document.getElementById("course-category") as HTMLSelectElement).value;
        
        alert(`Success! Course "${title}" (${category}) has been created successfully.`);
        createCourseForm.reset();
        closeCreateCourse();
      });
    }

    // 3. Profile dropup menu toggle
    profileBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      profileDropup.classList.toggle("hidden");
    });

    // Close menus if clicked outside
    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      
      if (!profileBtn.contains(target)) {
        profileDropup.classList.add("hidden");
      }
      if (!topAvatarBtn.contains(target)) {
        topProfileDropdown.classList.add("hidden");
      }
      if (inviteBtn && inviteDropdown && !inviteBtn.contains(target) && !inviteDropdown.contains(target)) {
        inviteDropdown.classList.add("hidden");
      }
      if (notificationsBellBtn && notificationsDropdown && !notificationsBellBtn.contains(target) && !notificationsDropdown.contains(target)) {
        notificationsDropdown.classList.add("hidden");
      }
      if (connectBtn && connectDropdown && !connectBtn.contains(target) && !connectDropdown.contains(target)) {
        connectDropdown.classList.add("hidden");
        connectArrow.classList.remove("rotate-180");
      }
    });

    // Top Profile dropdown toggle
    topAvatarBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      topProfileDropdown.classList.toggle("hidden");
      inviteDropdown.classList.add("hidden");
      notificationsDropdown.classList.add("hidden");
      connectDropdown.classList.add("hidden");
      connectArrow.classList.remove("rotate-180");
    });

    // Invite & Earn dropdown toggler
    inviteBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      inviteDropdown.classList.toggle("hidden");
      notificationsDropdown.classList.add("hidden");
      topProfileDropdown.classList.add("hidden");
      connectDropdown.classList.add("hidden");
      connectArrow.classList.remove("rotate-180");
    });

    // Copy Referral Link logic
    copyReferralBtn.addEventListener("click", () => {
      referralLinkInput.select();
      navigator.clipboard.writeText(referralLinkInput.value);
      copyToast.classList.remove("hidden");
      setTimeout(() => {
        copyToast.classList.add("hidden");
      }, 2000);
    });

    // Notifications dropdown toggler
    notificationsBellBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      notificationsDropdown.classList.toggle("hidden");
      inviteDropdown.classList.add("hidden");
      topProfileDropdown.classList.add("hidden");
      connectDropdown.classList.add("hidden");
      connectArrow.classList.remove("rotate-180");
    });

    // Connect dropdown toggler
    connectBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      const isHidden = connectDropdown.classList.toggle("hidden");
      if (isHidden) {
        connectArrow.classList.remove("rotate-180");
      } else {
        connectArrow.classList.add("rotate-180");
      }
      inviteDropdown.classList.add("hidden");
      notificationsDropdown.classList.add("hidden");
      topProfileDropdown.classList.add("hidden");
    });

    // Mark all as read logic
    markAllReadBtn.addEventListener("click", () => {
      bellUnreadDot.classList.add("hidden");
    });

    // 4. Log out button
    const triggerSignOut = async () => {
      try {
        await authClient.signOut();
        window.location.href = "/login";
      } catch (e) {
        console.error(e);
        window.location.href = "/login";
      }
    };
    logoutBtn.addEventListener("click", triggerSignOut);
    topLogoutBtn.addEventListener("click", triggerSignOut);

    // 5. Theme toggle switch
    themeToggleBtn.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
      updateThemeIcons();
    });

    // 6. Search input binding for keyboard shortcut focus
    window.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        openCommand();
      }
      if (e.key === "/" && document.activeElement?.tagName !== "INPUT" && document.activeElement?.tagName !== "TEXTAREA") {
        e.preventDefault();
        openCommand();
      }
      if (e.key === "Escape") {
        if (!createCourseModalOverlay.classList.contains("hidden")) {
          closeCreateCourse();
        }
      }
    });

    // 7. Command Dialog search and navigation
    commandSearch.addEventListener("input", () => {
      filterCommands(commandSearch.value);
    });

    commandSearch.addEventListener("keydown", (e) => {
      const visibleItems = Array.from(commandItems).filter(item => !item.classList.contains("hidden")) as HTMLButtonElement[];
      
      if (e.key === "Escape") {
        e.preventDefault();
        closeCommand();
      } else if (e.key === "ArrowDown") {
        e.preventDefault();
        if (visibleItems.length > 0) {
          const nextIndex = (activeIndex + 1) % visibleItems.length;
          updateSelection(visibleItems, nextIndex);
        }
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        if (visibleItems.length > 0) {
          const prevIndex = (activeIndex - 1 + visibleItems.length) % visibleItems.length;
          updateSelection(visibleItems, prevIndex);
        }
      } else if (e.key === "Enter") {
        e.preventDefault();
        if (visibleItems.length > 0 && visibleItems[activeIndex]) {
          visibleItems[activeIndex].click();
        }
      }
    });

    // Blog submenu toggle click listener
    blogBtn.addEventListener("click", (e) => {
      e.preventDefault();
      const isOpen = blogPanel.classList.contains("w-56");
      if (isOpen) {
        closeBlogPanel();
      } else {
        openBlogPanel();
        
        // Auto select "All Posts" subpage when opening the Blog panel
        const allPostsEl = document.getElementById("nav-blog-posts");
        if (allPostsEl) {
          allPostsEl.click();
        }
      }
    });

    blogCloseBtn.addEventListener("click", () => {
      closeBlogPanel();
    });

    // 8. Command items action triggers
    commandItems.forEach(item => {
      item.addEventListener("click", () => {
        const action = item.getAttribute("data-action");
        const targetId = item.getAttribute("data-target");

        if (action === "nav" && targetId) {
          const targetEl = document.getElementById(targetId);
          if (targetEl) {
            targetEl.click();
          }
          closeCommand();
        } else if (action === "nav-sub" && targetId) {
          openBlogPanel();

          const targetEl = document.getElementById(targetId);
          if (targetEl) {
            targetEl.click();
          }
          closeCommand();
        } else if (action === "theme") {
          themeToggleBtn.click();
          closeCommand();
        } else if (action === "logout") {
          closeCommand();
          triggerSignOut();
        }
      });
    });

    // 9. Navigation active states click highlights
    const items = document.querySelectorAll(".sidebar-item");
    items.forEach(item => {
      if (item.id === "blog-submenu-btn") return; // Skip default active state handler for blog toggle button
      item.addEventListener("click", (e) => {
        localStorage.setItem("active-nav-item", item.id);
        // Close the blog panel when clicking any other navigation item
        closeBlogPanel();

        items.forEach(el => {
          if (el.id === "nav-live-session") {
            el.classList.remove("active", "bg-muted/80", "shadow-2xs");
            el.classList.add("shadow-3xs");
          } else {
            el.classList.remove("active", "font-bold", "text-foreground", "bg-muted/80");
            el.classList.add("text-muted-foreground", "font-semibold");
          }
        });
        
        // Also clear active states from all submenu items
        const subItems = document.querySelectorAll(".sidebar-submenu-item");
        subItems.forEach(el => {
          el.classList.remove("active", "text-primary", "font-bold");
          el.classList.add("text-muted-foreground", "font-semibold");
        });
        
        if (item.id === "nav-live-session") {
          item.classList.add("active", "bg-muted/80", "shadow-2xs");
          item.classList.remove("shadow-3xs");
        } else {
          item.classList.add("active", "font-bold", "text-foreground", "bg-muted/80");
          item.classList.remove("text-muted-foreground", "font-semibold");
        }

        // Update Dashboard title
        const textSpan = item.querySelector(".sidebar-text");
        if (textSpan) {
          document.getElementById("dashboard-title")!.textContent = textSpan.textContent;
        }

        const viewMapping: Record<string, string> = {
          "nav-dashboard": "view-default",
          "nav-courses": "view-courses",
          "nav-analytics": "view-analytics",
          "nav-projects": "view-projects",
          "nav-live-session": "view-live-session",
          "nav-chat": "view-chat"
        };
        const targetView = viewMapping[item.id];
        if (targetView) {
          showView(targetView);
        }
      });
    });

    // 10. Submenu click highlights and title updates
    const subItems = document.querySelectorAll(".sidebar-submenu-item");
    subItems.forEach(subItem => {
      subItem.addEventListener("click", (e) => {
        e.preventDefault();
        localStorage.setItem("active-nav-item", subItem.id);
        
        // Clear active states from all regular items
        items.forEach(el => {
          if (el.id === "nav-live-session") {
            el.classList.remove("active", "bg-muted/80", "shadow-2xs");
            el.classList.add("shadow-3xs");
          } else {
            el.classList.remove("active", "font-bold", "text-foreground", "bg-muted/80");
            el.classList.add("text-muted-foreground", "font-semibold");
          }
        });

        // Clear active states from all other submenu items
        subItems.forEach(el => {
          el.classList.remove("active", "text-primary", "font-bold");
          el.classList.add("text-muted-foreground", "font-semibold");
        });

        // Highlight clicked submenu item
        subItem.classList.add("active", "text-primary", "font-bold");
        subItem.classList.remove("text-muted-foreground", "font-semibold");

        // Highlight parent Blog button
        blogBtn.classList.add("active", "font-bold", "text-foreground", "bg-muted/80");
        blogBtn.classList.remove("text-muted-foreground", "font-semibold");

        // Update Dashboard title
        const textSpan = subItem.querySelector("span");
        if (textSpan) {
          document.getElementById("dashboard-title")!.textContent = "Blog: " + textSpan.textContent;
        }

        if (subItem.id === "nav-blog-posts") {
          showView("view-blog-posts");
          blogStore.loadPosts();
          blogStore.loadCategories();
          blogStore.loadTags();
          blogStore.loadUsers();
        } else if (subItem.id === "nav-blog-categories") {
          showView("view-blog-categories");
          blogStore.loadCategories();
        } else if (subItem.id === "nav-blog-tags") {
          showView("view-blog-tags");
          blogStore.loadTags();
        }
      });
    });

    // Blog editor and form listeners
    const btnNew = document.getElementById("btn-new-post");
    if (btnNew) {
      btnNew.addEventListener("click", () => {
        blogStore.createPost();
      });
    }

    const btnBack = document.getElementById("btn-editor-back");
    if (btnBack) {
      btnBack.addEventListener("click", () => {
        showView("view-blog-posts");
        blogStore.loadPosts();
      });
    }

    const btnCancel = document.getElementById("btn-editor-cancel");
    if (btnCancel) {
      btnCancel.addEventListener("click", () => {
        showView("view-blog-posts");
        blogStore.loadPosts();
      });
    }

    const btnSave = document.getElementById("btn-editor-save");
    if (btnSave) {
      btnSave.addEventListener("click", () => {
        blogStore.savePost();
      });
    }

    const btnPublish = document.getElementById("btn-editor-publish");
    if (btnPublish) {
      btnPublish.addEventListener("click", () => {
        blogStore.savePost(true);
      });
    }

    // Slugify Title on the fly + URL Preview
    const titleInput = document.getElementById("post-title-input") as HTMLInputElement;
    const slugInput = document.getElementById("post-slug-input") as HTMLInputElement;
    
    const updateSlugPreview = () => {
      const previewLink = document.getElementById("post-slug-preview-link") as HTMLAnchorElement;
      if (slugInput && previewLink) {
        const slugVal = slugInput.value.trim();
        previewLink.textContent = `/blog/${slugVal}`;
        previewLink.href = `/blog/${slugVal}`;
      }
    };

    if (titleInput && slugInput) {
      titleInput.addEventListener("input", () => {
        if (!blogStore.state.currentEditingPostId) {
          slugInput.value = titleInput.value
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, "-")
            .replace(/(^-|-$)/g, "");
          updateSlugPreview();
        }
      });
      slugInput.addEventListener("input", updateSlugPreview);
    }

    // SEO Sheet wiring
    const btnEditorSeo = document.getElementById("btn-editor-seo");
    if (btnEditorSeo) {
      btnEditorSeo.addEventListener("click", () => blogStore.openSeoSheet());
    }
    const btnSeoClose = document.getElementById("btn-seo-sheet-close");
    if (btnSeoClose) {
      btnSeoClose.addEventListener("click", () => blogStore.closeSeoSheet());
    }
    const seoOverlay = document.getElementById("seo-sheet-overlay");
    if (seoOverlay) {
      seoOverlay.addEventListener("click", () => blogStore.closeSeoSheet());
    }
    // Live previews + character counters as the user types
    ["seo-meta-title", "seo-meta-description", "seo-canonical-url", "seo-og-image"].forEach((id) => {
      const el = document.getElementById(id);
      if (el) el.addEventListener("input", () => blogStore.updateSeoPreviews());
    });
    // Esc closes the sheet when it's open
    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      const panel = document.getElementById("seo-sheet-panel");
      if (panel && !panel.classList.contains("hidden")) blogStore.closeSeoSheet();
    });

    // Category Creation
    const catForm = document.getElementById("category-form");
    if (catForm) {
      catForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const name = (document.getElementById("category-name") as HTMLInputElement).value.trim();
        const slug = (document.getElementById("category-slug") as HTMLInputElement).value.trim();
        if (!name || !slug) return;
        
        const success = await blogStore.createCategory(name, slug);
        if (success) {
          (document.getElementById("category-name") as HTMLInputElement).value = "";
          (document.getElementById("category-slug") as HTMLInputElement).value = "";
        }
      });
    }

    const catNameInput = document.getElementById("category-name") as HTMLInputElement;
    const catSlugInput = document.getElementById("category-slug") as HTMLInputElement;
    if (catNameInput && catSlugInput) {
      catNameInput.addEventListener("input", () => {
        catSlugInput.value = catNameInput.value
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/(^-|-$)/g, "");
      });
    }

    // Tag Creation
    const tagForm = document.getElementById("tag-form");
    if (tagForm) {
      tagForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const name = (document.getElementById("tag-name") as HTMLInputElement).value.trim();
        const slug = (document.getElementById("tag-slug") as HTMLInputElement).value.trim();
        if (!name || !slug) return;

        const success = await blogStore.createTag(name, slug);
        if (success) {
          (document.getElementById("tag-name") as HTMLInputElement).value = "";
          (document.getElementById("tag-slug") as HTMLInputElement).value = "";
        }
      });
    }

    const tagNameInput = document.getElementById("tag-name") as HTMLInputElement;
    const tagSlugInput = document.getElementById("tag-slug") as HTMLInputElement;
    if (tagNameInput && tagSlugInput) {
      tagNameInput.addEventListener("input", () => {
        tagSlugInput.value = tagNameInput.value
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/(^-|-$)/g, "");
      });
    }

    // Search and Status filters using Shadcn Custom Dropdown UI
    const blogSearch = document.getElementById("blog-search") as HTMLInputElement;
    if (blogSearch) {
      blogSearch.addEventListener("input", () => {
        blogStore.setFilters(blogSearch.value, blogStore.state.statusFilter);
      });
    }

    // Setup Custom Dropdowns Interactivity
    const setupDropdowns = () => {
      const btnStatus = document.getElementById("btn-status-dropdown");
      const menuStatus = document.getElementById("dropdown-status-menu");
      const btnStatusTrash = document.getElementById("btn-status-trash");

      if (btnStatus && menuStatus) {
        btnStatus.addEventListener("click", (e) => {
          e.stopPropagation();
          menuStatus.classList.toggle("hidden");
          setTimeout(() => {
            menuStatus.classList.toggle("scale-95");
            menuStatus.classList.toggle("opacity-0");
            menuStatus.classList.toggle("scale-100");
            menuStatus.classList.toggle("opacity-100");
          }, 10);
        });

        menuStatus.querySelectorAll(".status-option").forEach(opt => {
          opt.addEventListener("click", (e) => {
            e.stopPropagation();
            const val = opt.getAttribute("data-value")!;
            const label = opt.querySelector("span")!.textContent!;
            
            document.getElementById("selected-status-label")!.textContent = label;
            blogStore.state.statusFilter = val;

            menuStatus.querySelectorAll(".check-icon").forEach(chk => chk.classList.add("hidden"));
            opt.querySelector(".check-icon")!.classList.remove("hidden");

            if (btnStatusTrash) {
              if (val === "trash") {
                btnStatusTrash.classList.remove("bg-card", "border-border", "text-foreground");
                btnStatusTrash.classList.add("bg-destructive/10", "border-destructive/20", "text-destructive");
              } else {
                btnStatusTrash.classList.remove("bg-destructive/10", "border-destructive/20", "text-destructive");
                btnStatusTrash.classList.add("bg-card", "border-border", "text-foreground");
              }
            }

            menuStatus.classList.remove("scale-100", "opacity-100");
            menuStatus.classList.add("scale-95", "opacity-0");
            setTimeout(() => {
              menuStatus.classList.add("hidden");
            }, 150);

            blogStore.setFilters(blogSearch ? blogSearch.value : "", val);
          });
        });
      }

      if (btnStatusTrash) {
        btnStatusTrash.addEventListener("click", () => {
          const isCurrentlyTrash = blogStore.state.statusFilter === "trash";
          const newVal = isCurrentlyTrash ? "all" : "trash";
          
          blogStore.state.statusFilter = newVal;

          if (newVal === "trash") {
            btnStatusTrash.classList.remove("bg-card", "border-border", "text-foreground");
            btnStatusTrash.classList.add("bg-destructive/10", "border-destructive/20", "text-destructive");
            
            document.getElementById("selected-status-label")!.textContent = "Trash";
            menuStatus?.querySelectorAll(".check-icon").forEach(chk => chk.classList.add("hidden"));
            (menuStatus?.querySelector('[data-value="trash"]') as HTMLElement)?.querySelector(".check-icon")?.classList.remove("hidden");
          } else {
            btnStatusTrash.classList.remove("bg-destructive/10", "border-destructive/20", "text-destructive");
            btnStatusTrash.classList.add("bg-card", "border-border", "text-foreground");
            
            document.getElementById("selected-status-label")!.textContent = "All Status";
            menuStatus?.querySelectorAll(".check-icon").forEach(chk => chk.classList.add("hidden"));
            (menuStatus?.querySelector('[data-value="all"]') as HTMLElement)?.querySelector(".check-icon")?.classList.remove("hidden");
          }

          blogStore.setFilters(blogSearch ? blogSearch.value : "", newVal);
        });
      }

      const btnCategory = document.getElementById("btn-category-dropdown");
      const menuCategory = document.getElementById("dropdown-category-menu");
      const chevronCategory = document.getElementById("chevron-category");
      const btnTags = document.getElementById("btn-tags-dropdown");
      const menuTags = document.getElementById("dropdown-tags-menu");
      const chevronTags = document.getElementById("chevron-tags");

      const closeMultiSelect = (menu: HTMLElement | null, chevron: HTMLElement | null) => {
        if (!menu) return;
        menu.classList.add("hidden");
        chevron?.classList.remove("rotate-180");
      };

      const toggleMultiSelect = (menu: HTMLElement | null, chevron: HTMLElement | null) => {
        if (!menu) return;
        const willOpen = menu.classList.contains("hidden");
        closeMultiSelect(menuCategory, chevronCategory);
        closeMultiSelect(menuTags, chevronTags);
        if (willOpen) {
          menu.classList.remove("hidden");
          chevron?.classList.add("rotate-180");
        }
      };

      if (btnCategory && menuCategory) {
        btnCategory.addEventListener("click", (e) => {
          e.stopPropagation();
          toggleMultiSelect(menuCategory, chevronCategory);
        });
      }
      if (btnTags && menuTags) {
        btnTags.addEventListener("click", (e) => {
          e.stopPropagation();
          toggleMultiSelect(menuTags, chevronTags);
        });
      }

      document.addEventListener("click", () => {
        if (menuStatus && !menuStatus.classList.contains("hidden")) {
          menuStatus.classList.remove("scale-100", "opacity-100");
          menuStatus.classList.add("scale-95", "opacity-0");
          setTimeout(() => { menuStatus.classList.add("hidden"); }, 150);
        }
        closeMultiSelect(menuCategory, chevronCategory);
        closeMultiSelect(menuTags, chevronTags);
      });

      const prevBtn = document.getElementById("btn-posts-prev");
      const nextBtn = document.getElementById("btn-posts-next");
      if (prevBtn) {
        prevBtn.addEventListener("click", () => {
          if (blogStore.state.currentPage > 1) {
            blogStore.state.currentPage--;
            blogStore.renderPosts();
          }
        });
      }
      if (nextBtn) {
        nextBtn.addEventListener("click", () => {
          let filtered = blogStore.state.posts;
          const query = blogStore.state.searchQuery;
          if (query) {
            filtered = filtered.filter((p: any) => p.title.toLowerCase().includes(query) || p.content?.toLowerCase().includes(query));
          }
          const isTrashView = blogStore.state.statusFilter === "trash";
          if (isTrashView) {
            filtered = filtered.filter((p: any) => p.trashed === true);
          } else {
            filtered = filtered.filter((p: any) => p.trashed === false);
            if (blogStore.state.statusFilter === "published") {
              filtered = filtered.filter((p: any) => p.published === true);
            } else if (blogStore.state.statusFilter === "draft") {
              filtered = filtered.filter((p: any) => p.published === false);
            }
          }
          const totalPages = Math.ceil(filtered.length / blogStore.state.pageSize);
          if (blogStore.state.currentPage < totalPages) {
            blogStore.state.currentPage++;
            blogStore.renderPosts();
          }
        });
      }
    };

    setupDropdowns();
  }

  function updateThemeIcons() {
    const isDark = document.documentElement.classList.contains("dark");
    if (isDark) {
      sunIcon.classList.remove("hidden");
      moonIcon.classList.add("hidden");
    } else {
      sunIcon.classList.add("hidden");
      moonIcon.classList.remove("hidden");
    }
  }

  init();
</script>
