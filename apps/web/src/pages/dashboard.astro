---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Dashboard - Hiver" hideHeader={true}>
  <!-- Main Dashboard Wrapper -->
  <div id="dashboard-root" class="hidden h-screen w-screen flex bg-background text-foreground overflow-hidden font-sans select-none antialiased">
    
    <!-- LEFT SIDEBAR -->
    <aside id="sidebar" class="w-64 border-r border-border bg-muted/20 flex flex-col justify-between shrink-0 h-full transition-all duration-300 z-30">
      
      <!-- Top Brand Header -->
      <div>
        <div class="h-16 flex items-center px-4 border-b border-border">
          <a href="/" class="flex items-center gap-2.5 select-none outline-hidden">
            <img
              src="/logo.png"
              class="w-8 h-8 object-contain"
              alt="HiverLMS Logo"
            />
            <span class="font-bold text-lg text-foreground tracking-tight sidebar-text">HiverLMS</span>
          </a>
        </div>
        
        <!-- Navigation Menu -->
        <div class="p-3">
          <p class="text-[11px] font-bold text-muted-foreground uppercase tracking-widest px-3.5 mb-2.5 sidebar-text">Overview</p>
          <nav class="space-y-1">
            
            <!-- Dashboard Link (Active initially) -->
            <a href="#" id="nav-dashboard" class="sidebar-item active w-full flex items-center justify-between px-3.5 py-2.5 rounded-lg text-sm font-bold text-foreground bg-muted/80 transition-colors">
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path>
                  <path d="m12 14 5-5"></path>
                  <circle cx="12" cy="12" r="1"></circle>
                </svg>
                <span class="sidebar-text">Dashboard</span>
              </div>
            </a>
            
            <!-- Courses Link -->
            <a href="#" id="nav-courses" class="sidebar-item w-full flex items-center justify-between px-3.5 py-2.5 rounded-lg text-sm font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                  <line x1="9" y1="9" x2="15" y2="9"></line>
                  <line x1="9" y1="13" x2="15" y2="13"></line>
                  <line x1="9" y1="17" x2="15" y2="17"></line>
                  <line x1="5" y1="9" x2="5" y2="9.01"></line>
                  <line x1="5" y1="13" x2="5" y2="13.01"></line>
                  <line x1="5" y1="17" x2="5" y2="17.01"></line>
                </svg>
                <span class="sidebar-text">Courses</span>
              </div>
            </a>
            
            <!-- Analytics Link -->
            <a href="#" id="nav-analytics" class="sidebar-item w-full flex items-center justify-between px-3.5 py-2.5 rounded-lg text-sm font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <line x1="18" x2="18" y1="20" y2="10"></line>
                  <line x1="12" x2="12" y1="20" y2="4"></line>
                  <line x1="6" x2="6" y1="20" y2="14"></line>
                </svg>
                <span class="sidebar-text">Analytics</span>
              </div>
            </a>
            
            <!-- Projects Link -->
            <a href="#" id="nav-projects" class="sidebar-item w-full flex items-center justify-between px-3.5 py-2.5 rounded-lg text-sm font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                </svg>
                <span class="sidebar-text">Projects</span>
              </div>
            </a>
            
            <!-- Team Link -->
            <a href="#" id="nav-team" class="sidebar-item w-full flex items-center justify-between px-3.5 py-2.5 rounded-lg text-sm font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
                <span class="sidebar-text">Team</span>
              </div>
            </a>
            
            <!-- Chat Link -->
            <a href="#" id="nav-chat" class="sidebar-item w-full flex items-center justify-between px-3.5 py-2.5 rounded-lg text-sm font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
                <span class="sidebar-text">Chat</span>
              </div>
              <span class="px-2 py-0.5 rounded-full bg-primary/20 text-primary text-[10px] font-bold sidebar-text shadow-3xs">3</span>
            </a>

            <!-- Blog Link (triggers WordPress-like adjacent sidebar panel) -->
            <a href="#" id="blog-submenu-btn" class="sidebar-item w-full flex items-center justify-between px-3.5 py-2.5 rounded-lg text-sm font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 4a2 2 0 00-2 2v8a2 2 0 002 2h2a2 2 0 002-2V14a2 2 0 00-2-2h-2m-11-4h4m-4 4h4m-4 4h4" />
                </svg>
                <span class="sidebar-text">Blog</span>
              </div>
              <svg id="blog-arrow" class="w-3.5 h-3.5 text-muted-foreground shrink-0 transition-transform duration-200 sidebar-text" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
            
          </nav>
        </div>
      </div>
      
      <!-- Bottom Section: Unlock Card & Profile -->
      <div class="p-3 border-t border-border space-y-3">
        
        <!-- Promo card "Unlock Everything" -->
        <div id="unlock-card" class="bg-card border border-border rounded-xl p-4 text-left relative overflow-hidden sidebar-text">
          <p class="font-bold text-sm text-foreground leading-tight">Unlock Everything</p>
          <p class="text-xs text-muted-foreground mt-2 leading-relaxed">
            Get instant access to all premium dashboards, templates, and UI components. Pay once, use forever in unlimited projects.
          </p>
          <button class="w-full flex items-center justify-center gap-2 mt-4 py-2 bg-primary text-primary-foreground hover:bg-primary/90 font-bold rounded-lg text-xs transition-colors cursor-pointer shadow-2xs">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            Get Full Access
          </button>
        </div>

        <!-- User Profile footer block -->
        <div class="relative">
          <button id="profile-block-btn" class="w-full flex items-center justify-between p-2 rounded-xl hover:bg-muted/60 transition-colors text-left border border-transparent hover:border-border cursor-pointer">
            <div class="flex items-center gap-3 min-w-0">
              <div class="w-8 h-8 rounded-full bg-primary text-white font-bold flex items-center justify-center shrink-0 border border-primary/20 text-xs shadow-sm" id="avatar-fallback">
                H
              </div>
              <div class="min-w-0 sidebar-text">
                <p class="text-xs font-semibold text-foreground truncate leading-none" id="profile-name">Hiver</p>
                <p class="text-[10px] text-muted-foreground truncate mt-1.5 leading-none" id="profile-email">admin@hiver.com.np</p>
              </div>
            </div>
            <svg class="w-3.5 h-3.5 text-muted-foreground shrink-0 sidebar-text" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
            </svg>
          </button>

          <!-- Profile drop-up menu matching the screenshot, positioned to the right of the sidebar -->
          <div id="profile-dropup-menu" class="absolute bottom-0 left-full ml-3 w-56 bg-card border border-border rounded-sm shadow-lg p-1.5 hidden z-[60]">
            <div class="px-3 py-2 border-b border-border/40 mb-1.5">
              <p class="text-xs font-bold text-foreground leading-none" id="menu-user-name">Hiver</p>
              <p class="text-[10px] text-muted-foreground mt-1 leading-none" id="menu-user-email">admin@hiver.com.np</p>
            </div>
            
            <a href="#" class="w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              Account
            </a>
            <a href="#" class="w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect width="20" height="14" x="2" y="5" rx="2"></rect>
                <line x1="2" x2="22" y1="10" y2="10"></line>
              </svg>
              Billing
            </a>
            <a href="#" class="w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
              Notifications
            </a>
            <button id="menu-logout-btn" class="w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-bold text-destructive hover:bg-destructive/10 transition-colors text-left border-t border-border/40 mt-1 cursor-pointer">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
              Log out
            </button>
          </div>
        </div>

      </div>
    </aside>

    <!-- SECONDARY SIDEBAR: BLOG PANEL -->
    <aside id="blog-panel" class="w-0 overflow-hidden bg-card/40 border-r border-border/0 flex flex-col justify-between shrink-0 h-full transition-all duration-300 z-25">
      <div>
        <div class="h-16 flex items-center justify-between px-4 border-b border-border">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-primary shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 4a2 2 0 00-2 2v8a2 2 0 002 2h2a2 2 0 002-2V14a2 2 0 00-2-2h-2m-11-4h4m-4 4h4m-4 4h4" />
            </svg>
            <span class="font-bold text-sm text-foreground tracking-tight">Blog Manager</span>
          </div>
          <button id="blog-panel-close" class="p-1 hover:bg-muted rounded text-muted-foreground hover:text-foreground cursor-pointer flex items-center justify-center animate-none transition-colors" aria-label="Close blog panel">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 6 6 18M6 6l12 12"></path>
            </svg>
          </button>
        </div>
        <div class="p-3">
          <p class="text-[11px] font-bold text-muted-foreground uppercase tracking-widest px-3.5 mb-2.5">Publishing</p>
          <nav class="space-y-1">
            <a href="#" id="nav-blog-posts" class="sidebar-submenu-item w-full flex items-center gap-3 px-3.5 py-2.5 rounded-lg text-sm font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
              <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <span>All Posts</span>
            </a>
            <a href="#" id="nav-blog-categories" class="sidebar-submenu-item w-full flex items-center gap-3 px-3.5 py-2.5 rounded-lg text-sm font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
              <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
              <span>Categories</span>
            </a>
            <a href="#" id="nav-blog-tags" class="sidebar-submenu-item w-full flex items-center gap-3 px-3.5 py-2.5 rounded-lg text-sm font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
              <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M6 20h4a2 2 0 001.414-.586l7-7a2 2 0 000-2.828l-4-4a2 2 0 00-2.828 0l-7 7A2 2 0 002 10v4a2 2 0 002 2z" />
              </svg>
              <span>Tags</span>
            </a>
          </nav>
        </div>
      </div>
    </aside>

    <!-- RIGHT CONTENT AREA -->
    <div class="flex-1 flex flex-col overflow-hidden h-full">
      
      <!-- TOP NAVBAR -->
      <header class="h-16 border-b border-border bg-card flex items-center justify-between px-4 md:px-6 shrink-0 z-20">
        
        <!-- Left Section: Collapse Toggle & Search -->
        <div class="flex items-center gap-4 flex-1">
          <!-- Sidebar Outer Collapse Toggle -->
          <button id="sidebar-collapse-toggle-outer" class="p-2 hover:bg-muted rounded-xl text-muted-foreground hover:text-foreground cursor-pointer" aria-label="Toggle sidebar">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2"></rect>
              <path d="M9 3v18"></path>
            </svg>
          </button>
          
          <!-- Search Bar -->
          <div class="relative w-full max-w-sm hidden sm:block">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-4 w-4 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" x2="16.65" y1="21" y2="16.65"></line>
              </svg>
            </div>
            <input type="text" id="navbar-search" class="block w-full pl-9 pr-12 py-2 text-sm bg-muted/30 border border-border rounded-sm focus:ring-1 focus:ring-foreground focus:outline-hidden font-medium placeholder-muted-foreground/80 text-foreground cursor-pointer select-none" placeholder="Search..." readonly />
            <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
              <kbd class="px-1.5 py-0.5 rounded border border-border/80 bg-card text-[9px] font-mono text-muted-foreground/75 font-semibold">⌘K</kbd>
            </div>
          </div>
        </div>

        <!-- Right Section: Actions & Utilities -->
        <div class="flex items-center gap-3">
          
          <!-- Invite & Earn Wrapper -->
          <div class="relative">
            <button id="invite-earn-btn" class="flex items-center gap-2 px-3 py-1.5 rounded-full border border-primary/20 bg-primary/10 hover:bg-primary/20 text-primary font-semibold text-xs transition-all cursor-pointer shadow-3xs">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="22" y1="2" x2="11" y2="13"></line>
                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
              </svg>
              <span class="hidden md:inline">Invite & Earn</span>
              <span class="px-1.5 py-0.5 rounded-full bg-primary text-primary-foreground font-bold text-[9px] shadow-3xs leading-none">₹250</span>
            </button>

            <!-- Invite & Earn Dropdown -->
            <div id="invite-earn-dropdown" class="absolute right-0 mt-2 w-80 bg-card border border-border rounded-sm shadow-lg p-4 hidden z-50">
              <h3 class="font-bold text-sm text-foreground mb-1.5">Invite Friends & Earn Credits</h3>
              <p class="text-[11px] text-muted-foreground leading-relaxed mb-3">
                Share your referral link with friends. You will earn <span class="text-primary font-bold">₹250 credits</span> when they complete registration, and they get a starting bonus of ₹100!
              </p>
              
              <!-- Credit Balance block -->
              <div class="bg-muted/40 rounded-lg p-3 mb-3 border border-border/40 flex justify-between items-center">
                <div>
                  <p class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider">Referral Balance</p>
                  <p class="text-lg font-bold text-foreground">₹250 <span class="text-xs font-semibold text-muted-foreground">Credits</span></p>
                </div>
                <button class="px-2.5 py-1 bg-primary text-primary-foreground hover:bg-primary/95 text-[10px] font-bold rounded-md transition-colors cursor-pointer">
                  Redeem
                </button>
              </div>

              <!-- Referral Code Field -->
              <div class="space-y-1.5">
                <label class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider">Your Referral Link</label>
                <div class="flex gap-1.5">
                  <input type="text" id="referral-link-input" readonly value="https://hiverlms.com/invite/PN250" class="flex-1 px-2.5 py-1.5 text-xs bg-muted/60 border border-border rounded-md text-muted-foreground select-all focus:outline-hidden font-medium" />
                  <button id="copy-referral-btn" class="px-3 py-1.5 bg-secondary text-secondary-foreground hover:bg-muted font-bold text-xs rounded-md border border-border transition-colors cursor-pointer flex-shrink-0">
                    Copy
                  </button>
                </div>
                <span id="copy-toast" class="text-[10px] text-emerald-500 font-semibold hidden">Link copied to clipboard!</span>
              </div>
            </div>
          </div>
          
          <!-- Notifications Wrapper -->
          <div class="relative">
            <button id="notifications-bell-btn" class="p-2 text-muted-foreground hover:text-foreground hover:bg-muted/60 rounded-xl transition-all cursor-pointer relative" aria-label="Notifications">
              <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
              <!-- Unread notification badge dot -->
              <span id="bell-unread-dot" class="absolute top-1.5 right-1.5 w-2 h-2 bg-destructive rounded-full border border-card shadow-3xs animate-pulse"></span>
            </button>

            <!-- Notifications Dropdown -->
            <div id="notifications-dropdown" class="absolute right-0 mt-2 w-96 bg-card border border-border rounded-sm shadow-lg p-1.5 hidden z-50">
              <div class="px-3 py-2 flex items-center justify-between border-b border-border/40 mb-1">
                <span class="font-bold text-xs text-foreground">Notifications</span>
                <button id="mark-all-read-btn" class="text-[10px] font-bold text-primary hover:underline cursor-pointer">
                  Mark all as read
                </button>
              </div>

              <!-- Notifications list -->
              <div class="max-h-[260px] overflow-y-auto space-y-0.5 scrollbar-thin">
                
                <!-- Notification Item 1: Referral Credited -->
                <div class="p-2.5 rounded-lg hover:bg-muted/40 transition-colors border border-transparent hover:border-border/20 flex gap-2.5 items-start">
