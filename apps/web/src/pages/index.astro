<script>
  import { authClient } from "../lib/auth-client";

  // Chart Interactive Logic
  const svg = document.getElementById("trading-chart-svg") as SVGSVGElement | null;
  const tooltip = document.getElementById("chart-tooltip") as HTMLDivElement | null;
  const tooltipTime = document.getElementById("tooltip-time");
  const tooltipOpen = document.getElementById("tooltip-open");
  const tooltipHigh = document.getElementById("tooltip-high");
  const tooltipLow = document.getElementById("tooltip-low");
  const tooltipClose = document.getElementById("tooltip-close");
  
  const verticalTracker = document.getElementById("chart-vertical-tracker");
  const horizontalTracker = document.getElementById("chart-horizontal-tracker");
  const liveDot = document.getElementById("chart-live-dot");
  const liveDotPulse = document.getElementById("chart-live-dot-pulse");
  const container = document.getElementById("interactive-chart-container");

  const candles = document.querySelectorAll(".candle-group");

  if (svg && container) {
    container.addEventListener("mousemove", (e) => {
      const rect = svg.getBoundingClientRect();
      const mouseX = e.clientX - rect.left;
      
      // Convert browser coordinate to SVG coordinate system (0 0 400 150)
      const svgX = (mouseX / rect.width) * 400;
      
      // Find nearest candle based on X coordinate
      let nearestCandle: Element | null = null;
      let minDistance = Infinity;
      
      candles.forEach((candle) => {
        const xAttr = candle.getAttribute("data-x");
        if (xAttr) {
          const candleX = parseFloat(xAttr);
          const distance = Math.abs(candleX - svgX);
          if (distance < minDistance) {
            minDistance = distance;
            nearestCandle = candle;
          }
        }
      });
      
      if (nearestCandle) {
        const cX = parseFloat((nearestCandle as Element).getAttribute("data-x") || "0");
        const cOpen = parseFloat((nearestCandle as Element).getAttribute("data-open") || "0");
        const cHigh = parseFloat((nearestCandle as Element).getAttribute("data-high") || "0");
        const cLow = parseFloat((nearestCandle as Element).getAttribute("data-low") || "0");
        const cClose = parseFloat((nearestCandle as Element).getAttribute("data-close") || "0");
        const cTime = (nearestCandle as Element).getAttribute("data-time") || "";
        
        // Calculate Close price Y coordinate (₹23,400 maps to 130, ₹23,550 maps to 40)
        const cY = 130 - (cClose - 23400) * 0.6;
        
        // Update vertical and horizontal crosshairs
        if (verticalTracker) {
          verticalTracker.setAttribute("x1", cX.toString());
          verticalTracker.setAttribute("x2", cX.toString());
          verticalTracker.classList.remove("opacity-0");
        }
        if (horizontalTracker) {
          horizontalTracker.setAttribute("y1", cY.toString());
          horizontalTracker.setAttribute("y2", cY.toString());
          horizontalTracker.classList.remove("opacity-0");
        }
        
        // Hide default live dot if hovering on other candles (candle 14 is the live one)
        if (nearestCandle !== document.getElementById("live-candle")) {
          liveDot?.classList.add("opacity-0");
          liveDotPulse?.classList.add("opacity-0");
        } else {
          liveDot?.classList.remove("opacity-0");
          liveDotPulse?.classList.remove("opacity-0");
        }
        
        // Update tooltip content
        if (tooltipTime) tooltipTime.textContent = cTime;
        if (tooltipOpen) tooltipOpen.textContent = `₹${cOpen.toLocaleString("en-IN")}`;
        if (tooltipHigh) tooltipHigh.textContent = `₹${cHigh.toLocaleString("en-IN")}`;
        if (tooltipLow) tooltipLow.textContent = `₹${cLow.toLocaleString("en-IN")}`;
        if (tooltipClose) tooltipClose.textContent = `₹${cClose.toLocaleString("en-IN")}`;
        
        // Show and position tooltip
        if (tooltip) {
          tooltip.classList.remove("hidden");
          const tooltipWidth = tooltip.offsetWidth;
          const tooltipHeight = tooltip.offsetHeight;
          
          let posX = e.clientX - rect.left - tooltipWidth / 2;
          let posY = e.clientY - rect.top - tooltipHeight - 15;
          
          // Boundaries checks
          if (posX < 10) posX = 10;
          if (posX + tooltipWidth > rect.width - 10) posX = rect.width - tooltipWidth - 10;
          if (posY < 10) posY = e.clientY - rect.top + 15;
          
          tooltip.style.left = `${posX}px`;
          tooltip.style.top = `${posY}px`;
        }
      }
    });
    
    container.addEventListener("mouseleave", () => {
      verticalTracker?.classList.add("opacity-0");
      horizontalTracker?.classList.add("opacity-0");
      tooltip?.classList.add("hidden");
      
      liveDot?.classList.remove("opacity-0");
      liveDotPulse?.classList.remove("opacity-0");
    });
  }

  async function checkSession() {
    try {
      const { data: session } = await authClient.getSession();
      if (session?.user) {
        // Option to redirect or change layout if authenticated
      }
    } catch (e) {
      // Not authenticated
    }
  }

  checkSession();
</script>
