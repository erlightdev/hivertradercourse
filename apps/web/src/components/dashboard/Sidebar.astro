---
// Sidebar Component
---
<!-- LEFT SIDEBAR -->
<aside id="sidebar" class="w-64 border-r border-border bg-muted/20 flex flex-col justify-between shrink-0 h-full transition-all duration-300 z-30">
  
  <!-- Top Brand Header -->
  <div>
    <div class="h-16 flex items-center px-4 border-b border-border">
      <a href="/" class="flex items-center gap-2.5 select-none outline-hidden">
        <img
          src="/logo.png"
          class="w-8 h-8 object-contain"
          alt="HiverLMS Logo"
        />
        <span class="font-bold text-lg text-foreground tracking-tight sidebar-text">HiverLMS</span>
      </a>
    </div>
    
    <!-- Navigation Menu -->
    <div class="p-3">
      <p class="text-[11px] font-bold text-muted-foreground uppercase tracking-widest px-3.5 mb-2.5 sidebar-text">Overview</p>
      <nav class="space-y-1">
        
        <!-- Dashboard Link (Active initially) -->
        <a href="#" id="nav-dashboard" class="sidebar-item active w-full flex items-center justify-between px-3.5 py-2.5 rounded-lg text-sm font-bold text-foreground bg-muted/80 transition-colors">
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path>
              <path d="m12 14 5-5"></path>
              <circle cx="12" cy="12" r="1"></circle>
            </svg>
            <span class="sidebar-text">Dashboard</span>
          </div>
        </a>
        
        <!-- Courses Link -->
        <a href="#" id="nav-courses" class="sidebar-item w-full flex items-center justify-between px-3.5 py-2.5 rounded-lg text-sm font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="9" y1="9" x2="15" y2="9"></line>
              <line x1="9" y1="13" x2="15" y2="13"></line>
              <line x1="9" y1="17" x2="15" y2="17"></line>
              <line x1="5" y1="9" x2="5" y2="9.01"></line>
              <line x1="5" y1="13" x2="5" y2="13.01"></line>
              <line x1="5" y1="17" x2="5" y2="17.01"></line>
            </svg>
            <span class="sidebar-text">Courses</span>
          </div>
        </a>
        
        <!-- Analytics Link -->
        <a href="#" id="nav-analytics" class="sidebar-item w-full flex items-center justify-between px-3.5 py-2.5 rounded-lg text-sm font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <line x1="18" x2="18" y1="20" y2="10"></line>
              <line x1="12" x2="12" y1="20" y2="4"></line>
              <line x1="6" x2="6" y1="20" y2="14"></line>
            </svg>
            <span class="sidebar-text">Analytics</span>
          </div>
        </a>
        
        <!-- Projects Link -->
        <a href="#" id="nav-projects" class="sidebar-item w-full flex items-center justify-between px-3.5 py-2.5 rounded-lg text-sm font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
            </svg>
            <span class="sidebar-text">Projects</span>
          </div>
        </a>
        
        <!-- 1:1 Live Session Link -->
        <a href="#" id="nav-live-session" class="sidebar-item w-full flex items-center justify-between px-3.5 py-2.5 rounded-lg text-sm font-bold text-primary hover:bg-muted/50 border border-primary/20 transition-all shadow-3xs">
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 shrink-0 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <span class="sidebar-text">1:1 Live Session</span>
          </div>
          <span class="px-2 py-0.5 rounded-full bg-primary text-primary-foreground text-[9px] font-bold sidebar-text shadow-3xs flex items-center gap-1 leading-none">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            LIVE
          </span>
        </a>
        
        <!-- Chat Link -->
        <a href="#" id="nav-chat" class="sidebar-item w-full flex items-center justify-between px-3.5 py-2.5 rounded-lg text-sm font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
            <span class="sidebar-text">Chat</span>
          </div>
          <span class="px-2 py-0.5 rounded-full bg-primary/20 text-primary text-[10px] font-bold sidebar-text shadow-3xs">3</span>
        </a>

        <!-- Blog Link (triggers WordPress-like adjacent sidebar panel) -->
        <a href="#" id="blog-submenu-btn" class="sidebar-item w-full flex items-center justify-between px-3.5 py-2.5 rounded-lg text-sm font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 4a2 2 0 00-2 2v8a2 2 0 002 2h2a2 2 0 002-2V14a2 2 0 00-2-2h-2m-11-4h4m-4 4h4m-4 4h4" />
            </svg>
            <span class="sidebar-text">Blog</span>
          </div>
          <svg id="blog-arrow" class="w-3.5 h-3.5 text-muted-foreground shrink-0 transition-transform duration-200 sidebar-text" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        
      </nav>
    </div>
  </div>
  
  <!-- Bottom Section: Unlock Card & Profile -->
  <div class="p-3 border-t border-border space-y-3">
    
    <!-- Promo card "Unlock Everything" -->
    <div id="unlock-card" class="bg-card border border-border rounded-xl p-4 text-left relative overflow-hidden sidebar-text">
      <p class="font-bold text-sm text-foreground leading-tight">Unlock Everything</p>
      <p class="text-[10px] text-muted-foreground mt-1.5 leading-normal">
        Get instant access to all premium dashboards, templates, and components.
      </p>
      <button class="w-full flex items-center justify-center gap-2 mt-4 py-2 bg-primary text-primary-foreground hover:bg-primary/90 font-bold rounded-lg text-xs transition-colors cursor-pointer shadow-2xs">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
        Get Full Access
      </button>
    </div>

    <!-- User Profile footer block -->
    <div class="relative">
      <button id="profile-block-btn" class="w-full flex items-center justify-between p-2 rounded-xl hover:bg-muted/60 transition-colors text-left border border-transparent hover:border-border cursor-pointer">
        <div class="flex items-center gap-3 min-w-0">
          <div class="w-8 h-8 rounded-full bg-primary text-white font-bold flex items-center justify-center shrink-0 border border-primary/20 text-xs shadow-sm" id="avatar-fallback">
            H
          </div>
          <div class="min-w-0 sidebar-text">
            <p class="text-xs font-semibold text-foreground truncate leading-none" id="profile-name">Hiver</p>
            <p class="text-[10px] text-muted-foreground truncate mt-1.5 leading-none" id="profile-email">admin@hiver.com.np</p>
          </div>
        </div>
        <svg class="w-3.5 h-3.5 text-muted-foreground shrink-0 sidebar-text" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
        </svg>
      </button>

      <!-- Profile drop-up menu matching the screenshot, positioned to the right of the sidebar -->
      <div id="profile-dropup-menu" class="absolute bottom-0 left-full ml-3 w-56 bg-card border border-border rounded-sm shadow-lg p-1.5 hidden z-[60]">
        <div class="px-3 py-2 border-b border-border/40 mb-1.5">
          <p class="text-xs font-bold text-foreground leading-none" id="menu-user-name">Hiver</p>
          <p class="text-[10px] text-muted-foreground mt-1 leading-none" id="menu-user-email">admin@hiver.com.np</p>
        </div>
        
        <a href="#" id="sidebar-account-btn" class="w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          Account
        </a>
        <a href="#" class="w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect width="20" height="14" x="2" y="5" rx="2"></rect>
            <line x1="2" y1="10" y2="10"></line>
          </svg>
          Billing
        </a>
        <a href="#" class="w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/50 transition-colors">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
          Notifications
        </a>
        <button id="menu-logout-btn" class="w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-bold text-destructive hover:bg-destructive/10 transition-colors text-left border-t border-border/40 mt-1 cursor-pointer">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
          Log out
        </button>
      </div>
    </div>

  </div>
</aside>
