---
// CommandDialog Component
---
<!-- Shadcn Command Dialog Overlay -->
<div id="command-dialog-overlay" class="fixed inset-0 z-[100] bg-background/80 backdrop-blur-xs hidden justify-center pt-[15vh]">
  <!-- Modal Card Box -->
  <div id="command-dialog-content" class="relative w-full max-w-lg bg-card text-card-foreground border border-border rounded-lg shadow-lg overflow-hidden flex flex-col scale-95 opacity-0 transition-all duration-200 ease-out max-h-[450px]">
    
    <!-- Top Input Panel -->
    <div class="flex items-center border-b border-border px-3 shrink-0">
      <svg class="mr-2 h-4 w-4 shrink-0 opacity-50 text-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" x2="16.65" y1="21" y2="16.65"></line>
      </svg>
      <input type="text" id="command-search-input" class="flex h-11 w-full bg-transparent py-3 text-xs outline-hidden placeholder:text-muted-foreground/60 text-foreground font-medium" placeholder="Type a command or search..." autocomplete="off" spellcheck="false" />
      <kbd class="pointer-events-none inline-flex h-5 select-none items-center gap-1 rounded border border-border/80 bg-muted px-1.5 font-mono text-[9px] font-medium text-muted-foreground/75 opacity-100">ESC</kbd>
    </div>
    
    <!-- Scrollable List -->
    <div id="command-results-list" class="max-h-[300px] overflow-y-auto p-1.5 space-y-1">
      
      <!-- Navigation Group -->
      <div class="command-group" data-group="navigation">
        <div class="px-2 py-1.5 text-[9px] font-bold text-muted-foreground/50 uppercase tracking-widest">Navigation</div>
        <div class="space-y-0.5">
          
          <button class="command-item w-full flex items-center justify-between px-2 py-2 rounded-sm text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/40 transition-colors cursor-pointer text-left outline-hidden" data-action="nav" data-target="nav-dashboard">
            <div class="flex items-center gap-2.5">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path>
                <path d="m12 14 5-5"></path>
                <circle cx="12" cy="12" r="1"></circle>
              </svg>
              <span>Dashboard</span>
            </div>
            <span class="text-[10px] font-mono text-muted-foreground/40">Overview</span>
          </button>
          
          <button class="command-item w-full flex items-center justify-between px-2 py-2 rounded-sm text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/40 transition-colors cursor-pointer text-left outline-hidden" data-action="nav" data-target="nav-courses">
            <div class="flex items-center gap-2.5">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="9" y1="9" x2="15" y2="9"></line>
                <line x1="9" y1="13" x2="15" y2="13"></line>
                <line x1="9" y1="17" x2="15" y2="17"></line>
              </svg>
              <span>Courses</span>
            </div>
            <span class="text-[10px] font-mono text-muted-foreground/40">Overview</span>
          </button>
          
          <button class="command-item w-full flex items-center justify-between px-2 py-2 rounded-sm text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/40 transition-colors cursor-pointer text-left outline-hidden" data-action="nav" data-target="nav-analytics">
            <div class="flex items-center gap-2.5">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <line x1="18" x2="18" y1="20" y2="10"></line>
                <line x1="12" x2="12" y1="20" y2="4"></line>
                <line x1="6" x2="6" y1="20" y2="14"></line>
              </svg>
              <span>Analytics</span>
            </div>
            <span class="text-[10px] font-mono text-muted-foreground/40">Overview</span>
          </button>
          
          <button class="command-item w-full flex items-center justify-between px-2 py-2 rounded-sm text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/40 transition-colors cursor-pointer text-left outline-hidden" data-action="nav" data-target="nav-projects">
            <div class="flex items-center gap-2.5">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
              </svg>
              <span>Projects</span>
            </div>
            <span class="text-[10px] font-mono text-muted-foreground/40">Overview</span>
          </button>
          
          <button class="command-item w-full flex items-center justify-between px-2 py-2 rounded-sm text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/40 transition-colors cursor-pointer text-left outline-hidden" data-action="nav" data-target="nav-live-session">
            <div class="flex items-center gap-2.5">
              <svg class="w-3.5 h-3.5 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              <span>1:1 Live Session</span>
            </div>
            <span class="text-[10px] font-mono text-primary/80">Premium</span>
          </button>
          
          <button class="command-item w-full flex items-center justify-between px-2 py-2 rounded-sm text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/40 transition-colors cursor-pointer text-left outline-hidden" data-action="nav" data-target="nav-chat">
            <div class="flex items-center gap-2.5">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
              </svg>
              <span>Chat</span>
            </div>
            <span class="text-[10px] font-mono text-muted-foreground/40">Overview</span>
          </button>

          <!-- Blog Submenu Commands -->
          <button class="command-item w-full flex items-center justify-between px-2 py-2 rounded-sm text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/40 transition-colors cursor-pointer text-left outline-hidden" data-action="nav-sub" data-target="nav-blog-posts" data-parent="blog-panel">
            <div class="flex items-center gap-2.5">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1" />
              </svg>
              <span>Blog: All Posts</span>
            </div>
            <span class="text-[10px] font-mono text-muted-foreground/40">Submenu</span>
          </button>

          <button class="command-item w-full flex items-center justify-between px-2 py-2 rounded-sm text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/40 transition-colors cursor-pointer text-left outline-hidden" data-action="nav-sub" data-target="nav-blog-categories" data-parent="blog-panel">
            <div class="flex items-center gap-2.5">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1" />
              </svg>
              <span>Blog: Categories</span>
            </div>
            <span class="text-[10px] font-mono text-muted-foreground/40">Submenu</span>
          </button>

          <button class="command-item w-full flex items-center justify-between px-2 py-2 rounded-sm text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/40 transition-colors cursor-pointer text-left outline-hidden" data-action="nav-sub" data-target="nav-blog-tags" data-parent="blog-panel">
            <div class="flex items-center gap-2.5">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1" />
              </svg>
              <span>Blog: Tags</span>
            </div>
            <span class="text-[10px] font-mono text-muted-foreground/40">Submenu</span>
          </button>
          
        </div>
      </div>
      
      <!-- Settings Group -->
      <div class="command-group" data-group="settings">
        <div class="px-2 py-1.5 text-[9px] font-bold text-muted-foreground/50 uppercase tracking-widest border-t border-border/40 mt-1.5">Settings</div>
        <div class="space-y-0.5">
          
          <button class="command-item w-full flex items-center justify-between px-2 py-2 rounded-sm text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/40 transition-colors cursor-pointer text-left outline-hidden" data-action="theme">
            <div class="flex items-center gap-2.5">
              <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="4"></circle>
                <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
              </svg>
              <span>Toggle Theme</span>
            </div>
            <span class="text-[10px] font-mono text-muted-foreground/40">Appearance</span>
          </button>
          
          <button class="command-item w-full flex items-center justify-between px-2 py-2 rounded-sm text-xs font-semibold text-muted-foreground hover:text-foreground hover:bg-muted/40 transition-colors cursor-pointer text-left outline-hidden" data-action="logout">
            <div class="flex items-center gap-2.5">
              <svg class="w-3.5 h-3.5 text-destructive" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
              <span class="text-destructive">Log Out</span>
            </div>
            <span class="text-[10px] font-mono text-destructive/40">Session</span>
          </button>
          
        </div>
      </div>

      <!-- No Results Found -->
      <div id="command-no-results" class="py-6 text-center text-xs text-muted-foreground/60 hidden">
        No results found.
      </div>

    </div>
    
  </div>
</div>
