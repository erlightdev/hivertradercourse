---
// ChatView Component (ChatGPT-like clean group chat UI)
---

<div id="view-chat" class="hidden mt-6 animate-fade-in h-[calc(100vh-11.5rem)] flex flex-col overflow-hidden bg-card border border-border rounded-xl">
  
  <!-- CHAT BOX INTEGRATED HEADER -->
  <div class="h-16 border-b border-border px-6 flex items-center shrink-0 bg-muted/10">
    <div class="flex items-center gap-3 min-w-0">
      <div class="w-8 h-8 rounded-lg bg-primary/10 border border-primary/20 flex items-center justify-center text-primary font-bold text-sm shrink-0 select-none">
        #
      </div>
      <div class="min-w-0">
        <div class="flex items-center gap-2">
          <h2 class="font-extrabold text-sm md:text-base text-foreground tracking-tight leading-none">Global Trading Desk</h2>
          <span class="flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-emerald-500/10 text-emerald-500 text-[10px] font-bold border border-emerald-500/15 leading-none select-none ml-1 shrink-0">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse shrink-0"></span>
            <span id="online-count">Connecting...</span>
          </span>
        </div>
        <p class="text-[10px] text-muted-foreground mt-1.5 font-medium truncate hidden sm:block">Public community discussions and live option flow forecasts</p>
      </div>
    </div>
  </div>

  <!-- CONVERSATION STREAM (SCROLLBOX - ChatGPT CLEAN FORMAT) -->
  <div id="chat-messages-container" class="flex-1 overflow-y-auto px-6 md:px-8 py-4 scrollbar-thin bg-card flex flex-col space-y-2.5">
    <!-- Messages are generated programmatically here -->
  </div>

  <!-- INPUT AREA WRAPPER -->
  <div class="p-6 bg-card border-t border-border/5 shrink-0 flex flex-col gap-3">
    <!-- QUICK TRADING EMOJI TRAY -->
    <div class="max-w-3xl mx-auto w-full flex gap-1.5 items-center overflow-x-auto scrollbar-none shrink-0 px-2">
      <span class="text-[10px] font-bold text-muted-foreground uppercase tracking-wider shrink-0 mr-1.5">Trade Emojis:</span>
      <button type="button" data-emoji="📈 Bullish" class="quick-emoji-btn px-2.5 py-1 bg-muted/20 hover:bg-muted border border-border/40 text-[10px] font-bold text-foreground rounded-full transition-all cursor-pointer shadow-3xs hover:scale-105 active:scale-95 shrink-0">📈 Bullish</button>
      <button type="button" data-emoji="📉 Bearish" class="quick-emoji-btn px-2.5 py-1 bg-muted/20 hover:bg-muted border border-border/40 text-[10px] font-bold text-foreground rounded-full transition-all cursor-pointer shadow-3xs hover:scale-105 active:scale-95 shrink-0">📉 Bearish</button>
      <button type="button" data-emoji="🚀 Breakout" class="quick-emoji-btn px-2.5 py-1 bg-muted/20 hover:bg-muted border border-border/40 text-[10px] font-bold text-foreground rounded-full transition-all cursor-pointer shadow-3xs hover:scale-105 active:scale-95 shrink-0">🚀 Breakout</button>
      <button type="button" data-emoji="💰 Target Hit" class="quick-emoji-btn px-2.5 py-1 bg-muted/20 hover:bg-muted border border-border/40 text-[10px] font-bold text-foreground rounded-full transition-all cursor-pointer shadow-3xs hover:scale-105 active:scale-95 shrink-0">💰 Target</button>
      <button type="button" data-emoji="⚠️ Stoploss" class="quick-emoji-btn px-2.5 py-1 bg-muted/20 hover:bg-muted border border-border/40 text-[10px] font-bold text-foreground rounded-full transition-all cursor-pointer shadow-3xs hover:scale-105 active:scale-95 shrink-0">⚠️ Stoploss</button>
      <button type="button" data-emoji="📊 Chart Set" class="quick-emoji-btn px-2.5 py-1 bg-muted/20 hover:bg-muted border border-border/40 text-[10px] font-bold text-foreground rounded-full transition-all cursor-pointer shadow-3xs hover:scale-105 active:scale-95 shrink-0">📊 Chart Set</button>
      <button type="button" data-emoji="💸 Decay" class="quick-emoji-btn px-2.5 py-1 bg-muted/20 hover:bg-muted border border-border/40 text-[10px] font-bold text-foreground rounded-full transition-all cursor-pointer shadow-3xs hover:scale-105 active:scale-95 shrink-0">💸 Decay</button>
      <button type="button" data-emoji="🐋 Whale Order" class="quick-emoji-btn px-2.5 py-1 bg-muted/20 hover:bg-muted border border-border/40 text-[10px] font-bold text-foreground rounded-full transition-all cursor-pointer shadow-3xs hover:scale-105 active:scale-95 shrink-0">🐋 Whale</button>
    </div>

    <!-- TYPING INDICATOR -->
    <div class="max-w-3xl mx-auto w-full px-4 h-4">
      <p id="chat-typing-indicator" class="text-[11px] text-muted-foreground/60 italic opacity-0 transition-opacity duration-200 font-semibold"></p>
    </div>

    <!-- ChatGPT STYLE INPUT BOX -->
    <form id="chat-input-form" class="max-w-3xl mx-auto w-full relative">
      <!-- Floating Emoji Picker Popover -->
      <div id="emoji-picker-container" class="absolute bottom-16 right-0 z-50 hidden shadow-xl border border-border rounded-xl overflow-hidden animate-fade-in">
        <emoji-picker></emoji-picker>
      </div>

      <div class="relative bg-muted/30 border border-border/80 focus-within:border-primary/50 focus-within:ring-1 focus-within:ring-primary/25 rounded-2xl pl-4 pr-16 py-3 shadow-3xs transition-all flex items-center">
        <input type="text" id="chat-message-input" autocomplete="off" class="w-full bg-transparent border-0 outline-hidden focus:ring-0 text-sm font-semibold text-foreground placeholder-muted-foreground/60 pr-16 py-0.5" placeholder="Type a message inside Global Trading Desk..." />
        
        <!-- Smiley Emoji Toggle -->
        <button type="button" id="chat-emoji-toggle-btn" class="absolute right-12 top-1/2 -translate-y-1/2 p-1.5 text-muted-foreground hover:text-foreground cursor-pointer transition-colors" title="Choose emoji">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
            <line x1="9" y1="9" x2="9.01" y2="9"></line>
            <line x1="15" y1="9" x2="15.01" y2="9"></line>
          </svg>
        </button>

        <!-- Nested Send Button inside input pill -->
        <button type="submit" class="absolute right-2.5 top-1/2 -translate-y-1/2 p-2 bg-primary text-primary-foreground hover:bg-primary/95 hover:shadow-2xs active:translate-y-[1px] rounded-xl transition-all cursor-pointer flex items-center justify-center shrink-0">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </button>
      </div>
    </form>
  </div>

</div>

<script>
  import "emoji-picker-element";
  import * as Ably from 'ably';
  import { ChatClient } from '@ably/chat';
  import { PUBLIC_ABLY_KEY, PUBLIC_SERVER_URL } from 'astro:env/client';
  import { authClient } from "../../lib/auth-client";
  import { toast } from "../../lib/dashboard-store";

  // Elements
  const msgContainer = document.getElementById("chat-messages-container")!;
  const inputForm = document.getElementById("chat-input-form") as HTMLFormElement;
  const msgInput = document.getElementById("chat-message-input") as HTMLInputElement;
  const emojiToggleBtn = document.getElementById("chat-emoji-toggle-btn")!;
  const emojiPickerContainer = document.getElementById("emoji-picker-container")!;
  const emojiPickerElement = document.querySelector("emoji-picker")!;

  let myName = "Hiver";
  let myInitials = "H";
  let myEmail = "";
  let avatarColorClass = "bg-primary";

  // Ably References
  let realtimeClient: Ably.Realtime | null = null;
  let chatClient: ChatClient | null = null;
  let room: any = null;

  // Messages Database
  type Msg = {
    id: string;
    sender: string;
    role?: string;
    avatar: string;
    avatarColor: string;
    text: string;
    time: string;
    isMe: boolean;
  };

  let messages: Msg[] = [];

  // Fetch active user session & Bootstrap Ably
  async function loadUser() {
    try {
      const { data: session } = await authClient.getSession();
      if (session?.user) {
        myName = session.user.name || "Hiver";
        myEmail = session.user.email || "";
        myInitials = myName.split(" ").map(n => n[0]).join("").toUpperCase();

        // Retrieve current avatar theme color to match settings
        const currentTheme = localStorage.getItem("profile-avatar-theme") || "default";
        if (currentTheme === "emerald") {
          avatarColorClass = "bg-gradient-to-br from-emerald-400 to-teal-500";
        } else if (currentTheme === "blue") {
          avatarColorClass = "bg-gradient-to-br from-blue-400 to-indigo-500";
        } else if (currentTheme === "indigo") {
          avatarColorClass = "bg-gradient-to-br from-indigo-400 to-purple-500";
        } else if (currentTheme === "rose") {
          avatarColorClass = "bg-gradient-to-br from-rose-400 to-pink-500";
        } else {
          avatarColorClass = "bg-primary";
        }

        // Update UI panels for our my-user footer
        const myAvatars = document.querySelectorAll(".chat-my-avatar");
        myAvatars.forEach(el => {
          el.className = `chat-my-avatar w-9 h-9 rounded-full text-white font-bold text-xs flex items-center justify-center shrink-0 border border-primary/25 shadow-xs select-none ${avatarColorClass}`;
          el.textContent = myInitials;
        });

        // Initialize Ably Chat once we have the user identity
        await initAbly(myEmail || session.user.id || "anonymous-user");
      }
    } catch (e) {
      console.error(e);
    }
  }

  // Initialize Ably Realtime and Ably Chat SDK
  async function initAbly(clientId: string) {
    if (realtimeClient) return;

    try {
      realtimeClient = new Ably.Realtime({
        authCallback: async (tokenParams, callback) => {
          try {
            const res = await fetch(`${PUBLIC_SERVER_URL}/api/chat/auth`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify(tokenParams),
              credentials: 'include'
            });
            if (!res.ok) {
              throw new Error('System authentication failed');
            }
            const tokenRequest = await res.json();
            callback(null, tokenRequest);
          } catch (err: any) {
            console.error('Ably authCallback error:', err);
            callback(err, null);
          }
        },
        clientId: clientId,
      });

      realtimeClient.connection.on("connected", () => {
        console.log("Ably Chat connection established.");
      });

      realtimeClient.connection.on("failed", (err) => {
        console.error("Ably Chat connection failed:", err);
        toast.error("Failed to connect to real-time server.");
      });

      chatClient = new ChatClient(realtimeClient);
      room = await chatClient.rooms.get("global-trading-desk");

      await room.attach();

      // Clear static dummy list to replace with live/history
      messages.length = 0;

      // Subscribe to live room messages
      const { historyBeforeSubscribe } = room.messages.subscribe((event: any) => {
        handleIncomingMessage(event);
      });

      // Fetch message history for the room (up to 30 messages)
      try {
        const historicalMessages = await historyBeforeSubscribe({ limit: 30 });
        if (historicalMessages && historicalMessages.items) {
          const sortedItems = [...historicalMessages.items].reverse();
          sortedItems.forEach((msg: any) => {
            messages.push(mapAblyMessageToMsg(msg));
          });
          renderMessages();
        }
      } catch (histError) {
        console.error("Failed to load history, falling back to empty state:", histError);
        renderMessages();
      }

      // Enter the presence set so we are visible to others
      await room.presence.enter({
        sender: myName,
        avatar: myInitials,
        avatarColor: avatarColorClass,
        role: myEmail === 'admin@hiver.com' ? 'Admin' : 'Trader'
      });

      // Listen to presence events to track active participants
      room.presence.subscribe(() => {
        updateOnlineCount();
      });

      // Run initial online count update
      updateOnlineCount();

      // Subscribe to typing events
      room.typing.subscribe((event: any) => {
        updateTypingIndicator(event);
      });

    } catch (err) {
      console.error("Ably Chat setup error:", err);
    }
  }

  // Map Ably Message to our internal UI Msg representation
  function mapAblyMessageToMsg(message: any): Msg {
    const metadata = message.metadata || {};
    const isMe = message.clientId === (realtimeClient?.auth?.clientId || myEmail);
    return {
      id: message.serial,
      sender: metadata.sender || message.clientId || "Anonymous",
      role: metadata.role || (message.clientId === 'admin@hiver.com' ? 'Admin' : undefined),
      avatar: metadata.avatar || "U",
      avatarColor: metadata.avatarColor || "bg-primary",
      text: message.text || "",
      time: new Date(message.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
      isMe
    };
  }

  // Handle incoming message events (Create, Update, Delete)
  function handleIncomingMessage(event: any) {
    const type = event.type;
    switch (type) {
      case "message.created": {
        const newMsg = mapAblyMessageToMsg(event.message);
        if (!messages.some(m => m.id === newMsg.id)) {
          messages.push(newMsg);
          if (messages.length > 100) {
            messages.shift();
          }
          renderMessages();
        }
        break;
      }
      case "message.updated": {
        const idx = messages.findIndex(m => m.id === event.message.serial);
        if (idx !== -1) {
          const oldMsg = messages[idx];
          if (!event.message.version || event.message.version.serial > (oldMsg as any).versionSerial) {
            messages[idx] = mapAblyMessageToMsg(event.message);
            renderMessages();
          }
        }
        break;
      }
      case "message.deleted": {
        messages = messages.filter(m => m.id !== event.message.serial);
        renderMessages();
        break;
      }
    }
  }

  // Update dynamic header text with actual number of present users
  async function updateOnlineCount() {
    if (!room) return;
    try {
      const presentMembers = await room.presence.get();
      const uniqueClients = new Set();
      presentMembers.forEach((member: any) => {
        uniqueClients.add(member.clientId);
      });

      const count = uniqueClients.size;
      const countEl = document.getElementById("online-count");
      if (countEl) {
        countEl.textContent = `${count} online`;
      }
    } catch (err) {
      console.error("Error retrieving presence count:", err);
    }
  }

  // Update typing indicator box above input pill
  function updateTypingIndicator(event: any) {
    const indicatorEl = document.getElementById("chat-typing-indicator");
    if (!indicatorEl) return;

    const otherTypers = (event.currentTypers || []).filter(
      (typer: any) => typer.clientId !== (realtimeClient?.auth?.clientId || myEmail)
    );

    if (otherTypers.length === 0) {
      indicatorEl.textContent = "";
      indicatorEl.classList.add("opacity-0");
    } else if (otherTypers.length === 1) {
      const rawName = otherTypers[0].clientId.split("@")[0] || "Someone";
      const name = rawName.charAt(0).toUpperCase() + rawName.slice(1);
      indicatorEl.textContent = `${name} is typing...`;
      indicatorEl.classList.remove("opacity-0");
    } else {
      indicatorEl.textContent = `${otherTypers.length} people are typing...`;
      indicatorEl.classList.remove("opacity-0");
    }
  }

  // Stable, trading-related soft pastel borderless colored tints for compact bubbles
  const TINTS = [
    "bg-emerald-500/15 text-emerald-800 dark:text-emerald-300",
    "bg-amber-500/15 text-amber-800 dark:text-amber-300",
    "bg-teal-500/15 text-teal-800 dark:text-teal-300",
    "bg-rose-500/15 text-rose-800 dark:text-rose-300",
    "bg-blue-500/15 text-blue-800 dark:text-blue-300",
    "bg-indigo-500/15 text-indigo-800 dark:text-indigo-300",
    "bg-purple-500/15 text-purple-800 dark:text-purple-300"
  ];

  function getSenderTint(sender: string): string {
    let hash = 0;
    for (let i = 0; i < sender.length; i++) {
      hash = sender.charCodeAt(i) + ((hash << 5) - hash);
    }
    const index = Math.abs(hash) % TINTS.length;
    return TINTS[index];
  }

  // Draw message stream in beautiful, compact Messenger-style bubbles
  function renderMessages() {
    msgContainer.innerHTML = "";

    if (messages.length === 0) {
      msgContainer.innerHTML = `
        <div class="h-full flex items-center justify-center text-center p-6 select-none flex-1">
          <div class="space-y-1.5">
            <p class="text-base font-bold text-muted-foreground">No messages yet</p>
            <p class="text-xs text-muted-foreground/60 leading-normal font-medium font-sans">Type a message to start community conversation!</p>
          </div>
        </div>
      `;
      return;
    }

    messages.forEach(msg => {
      const isMe = msg.isMe;
      
      const rowHtml = isMe
        ? `
          <div class="py-1.5 flex gap-2.5 items-end justify-end ml-auto max-w-xl animate-slide-up select-text">
            <div class="space-y-1 flex flex-col items-end">
              <div class="flex items-baseline gap-1.5 pr-1">
                <span class="text-[8px] text-muted-foreground/50 font-bold">${msg.time}</span>
                <span class="text-[10px] font-bold text-foreground/80">You</span>
              </div>
              <div class="px-3.5 py-1.5 rounded-2xl rounded-tr-none bg-gradient-to-b from-[#e88c73] via-[#df775b] to-[#c8664d] text-white text-[13px] font-semibold leading-snug shadow-3xs max-w-md whitespace-pre-wrap">${msg.text}</div>
            </div>
            <div class="w-6.5 h-6.5 rounded-full ${msg.avatarColor} text-white text-[9px] font-bold flex items-center justify-center border border-primary/20 shadow-3xs select-none shrink-0">${msg.avatar}</div>
          </div>
        `
        : `
          <div class="py-1.5 flex gap-2.5 items-start max-w-xl animate-slide-up select-text">
            <div class="w-6.5 h-6.5 rounded-full ${msg.avatarColor} text-white text-[9px] font-bold flex items-center justify-center border border-border/10 shadow-3xs select-none shrink-0">${msg.avatar}</div>
            <div class="space-y-1">
              <div class="flex items-baseline gap-1.5 pl-1">
                <span class="text-[10px] font-bold text-foreground/85">${msg.sender}</span>
                ${msg.role ? `<span class="px-1 py-0.2 bg-primary/10 text-primary text-[6px] font-extrabold rounded uppercase leading-none border border-primary/10 shrink-0">${msg.role}</span>` : ""}
                <span class="text-[8px] text-muted-foreground/50 font-bold">${msg.time}</span>
              </div>
              <div class="px-3.5 py-1.5 rounded-2xl rounded-tl-none font-semibold text-[13px] leading-snug shadow-3xs whitespace-pre-wrap max-w-md ${getSenderTint(msg.sender)}">${msg.text}</div>
            </div>
          </div>
        `;

      msgContainer.insertAdjacentHTML("beforeend", rowHtml);
    });

    // Auto scroll bottom
    msgContainer.scrollTop = msgContainer.scrollHeight;
  }

  // Handle send message
  inputForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const text = msgInput.value.trim();
    if (!text) return;

    msgInput.value = "";

    if (room) {
      try {
        await room.messages.send({
          text,
          metadata: {
            sender: myName,
            avatar: myInitials,
            avatarColor: avatarColorClass,
            role: myEmail === 'admin@hiver.com' ? 'Admin' : 'Trader'
          }
        });
        room.typing.stop();
      } catch (err) {
        console.error("Failed to send message over Ably:", err);
        toast.error("Failed to send message. Please try again.");
      }
    } else {
      // Fallback local array
      const newMsg: Msg = {
        id: Date.now().toString(),
        sender: myName,
        avatar: myInitials,
        avatarColor: avatarColorClass,
        text,
        time: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
        isMe: true
      };
      messages.push(newMsg);
      renderMessages();
    }
  });

  // Track keystrokes for typing status
  msgInput.addEventListener("input", () => {
    if (room) {
      room.typing.keystroke();
    }
  });

  // Quick trade emoji tray listener
  const emojiBtns = document.querySelectorAll(".quick-emoji-btn") as NodeListOf<HTMLButtonElement>;
  emojiBtns.forEach(btn => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      const emoji = btn.getAttribute("data-emoji")!;
      msgInput.value += (msgInput.value ? " " : "") + emoji;
      msgInput.focus();
      if (room) {
        room.typing.keystroke();
      }
    });
  });

  // Run on dashboard navigation triggers to sync details
  const chatNavBtn = document.getElementById("nav-chat");
  if (chatNavBtn) {
    chatNavBtn.addEventListener("click", () => {
      loadUser();
      renderMessages();
    });
  }

  // Emoji Picker Toggle & Select Listeners
  if (emojiToggleBtn && emojiPickerContainer && emojiPickerElement) {
    emojiToggleBtn.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      emojiPickerContainer.classList.toggle("hidden");
    });

    emojiPickerElement.addEventListener("emoji-click", (e: any) => {
      const emojiUnicode = e.detail.unicode;
      msgInput.value += emojiUnicode;
      msgInput.focus();
      if (room) {
        room.typing.keystroke();
      }
    });

    // Close on clicking outside
    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (!emojiPickerContainer.contains(target) && !emojiToggleBtn.contains(target)) {
        emojiPickerContainer.classList.add("hidden");
      }
    });
  }

  // Load initially
  loadUser();
  renderMessages();
</script>