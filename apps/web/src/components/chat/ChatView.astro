---
// ChatView Component (Optimized single-panel Group Chat terminal)
---

<div id="view-chat" class="hidden mt-6 animate-fade-in h-[calc(100vh-12rem)] min-h-[500px]">
  <!-- CHAT MAIN SHELL -->
  <div class="bg-card border border-border rounded-xl shadow-sm h-full flex flex-col overflow-hidden">
    
    <!-- CHAT HEADER -->
    <div class="h-16 border-b border-border px-6 flex items-center justify-between shrink-0 bg-muted/10">
      <div class="flex items-center gap-3 min-w-0">
        <!-- Unified Group Icon -->
        <div class="w-9 h-9 rounded-lg bg-primary/10 border border-primary/20 flex items-center justify-center text-primary font-bold shrink-0 select-none">
          #
        </div>
        <div class="min-w-0">
          <div class="flex items-center gap-2.5">
            <h2 class="font-extrabold text-sm md:text-base text-foreground tracking-tight leading-none">global-trading-desk</h2>
            <span class="flex items-center gap-1 px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-500 text-[9px] font-bold border border-emerald-500/15 leading-none">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse shrink-0"></span>
              14 Online
            </span>
          </div>
          <p class="text-[11px] text-muted-foreground mt-1.5 font-medium truncate hidden sm:block">Public trading floor for sharing chart patterns, market news, and option forecasts.</p>
        </div>
      </div>

      <div class="flex items-center gap-2">
        <!-- Clear Chat history button -->
        <button id="chat-clear-btn" class="p-2 hover:bg-muted rounded-lg text-muted-foreground hover:text-foreground cursor-pointer transition-colors" title="Clear conversation history">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 6h18M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h8c1 0 2 1 2 2v2"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- CONVERSATION STREAM (SCROLLBOX - OPTIMIZED FOR TEXT READABILITY) -->
    <div id="chat-messages-container" class="flex-1 overflow-y-auto p-6 md:p-8 space-y-6 scrollbar-thin bg-card">
      <!-- Messages are generated programmatically here -->
    </div>

    <!-- QUICK TRADING EMOJI TRAY -->
    <div class="px-6 py-2 border-t border-border bg-muted/10 flex gap-1.5 items-center overflow-x-auto scrollbar-none shrink-0">
      <span class="text-[10px] font-bold text-muted-foreground uppercase tracking-wider shrink-0 mr-2">Trade Emojis:</span>
      <button data-emoji="📈 Bullish" class="quick-emoji-btn px-2.5 py-1 bg-card hover:bg-muted border border-border/80 text-[10px] font-bold text-foreground rounded-full transition-all cursor-pointer shadow-3xs hover:scale-105 active:scale-95 shrink-0">📈 Bullish</button>
      <button data-emoji="📉 Bearish" class="quick-emoji-btn px-2.5 py-1 bg-card hover:bg-muted border border-border/80 text-[10px] font-bold text-foreground rounded-full transition-all cursor-pointer shadow-3xs hover:scale-105 active:scale-95 shrink-0">📉 Bearish</button>
      <button data-emoji="🚀 Breakout" class="quick-emoji-btn px-2.5 py-1 bg-card hover:bg-muted border border-border/80 text-[10px] font-bold text-foreground rounded-full transition-all cursor-pointer shadow-3xs hover:scale-105 active:scale-95 shrink-0">🚀 Breakout</button>
      <button data-emoji="💰 Target Hit!" class="quick-emoji-btn px-2.5 py-1 bg-card hover:bg-muted border border-border/80 text-[10px] font-bold text-foreground rounded-full transition-all cursor-pointer shadow-3xs hover:scale-105 active:scale-95 shrink-0">💰 Target Hit!</button>
      <button data-emoji="⚠️ Stoploss Hit" class="quick-emoji-btn px-2.5 py-1 bg-card hover:bg-muted border border-border/80 text-[10px] font-bold text-foreground rounded-full transition-all cursor-pointer shadow-3xs hover:scale-105 active:scale-95 shrink-0">⚠️ Stoploss</button>
    </div>

    <!-- MESSAGE INPUT FOOTER -->
    <form id="chat-input-form" class="p-4 border-t border-border flex items-center gap-3 bg-muted/20 shrink-0">
      <!-- User profile preview indicator -->
      <div class="chat-my-avatar w-9 h-9 rounded-full bg-primary text-white font-bold text-xs flex items-center justify-center shrink-0 border border-primary/25 shadow-xs select-none">
        H
      </div>

      <div class="relative flex-1">
        <input type="text" id="chat-message-input" autocomplete="off" class="w-full px-4 py-3 pr-10 text-xs bg-card border border-border rounded-lg focus:ring-1 focus:ring-primary focus:outline-hidden text-foreground font-semibold placeholder:text-muted-foreground/60 shadow-3xs transition-all" placeholder="Type a message inside #global-trading-desk..." />
        <!-- Attachment clips icon -->
        <button type="button" class="absolute right-3.5 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground cursor-pointer transition-colors" title="Attach file">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
          </svg>
        </button>
      </div>

      <button type="submit" class="p-3 bg-primary text-primary-foreground hover:bg-primary/95 hover:shadow-2xs active:translate-y-[1px] rounded-lg transition-all cursor-pointer flex items-center justify-center shrink-0">
        <svg class="w-4.5 h-4.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </form>

  </div>
</div>

<script>
  import { authClient } from "../../lib/auth-client";
  import { toast } from "../../lib/dashboard-store";

  // Elements
  const msgContainer = document.getElementById("chat-messages-container")!;
  const inputForm = document.getElementById("chat-input-form") as HTMLFormElement;
  const msgInput = document.getElementById("chat-message-input") as HTMLInputElement;
  const clearBtn = document.getElementById("chat-clear-btn")!;

  let myName = "Hiver";
  let myInitials = "H";
  let avatarColorClass = "bg-primary";

  // Messages Database
  type Msg = {
    id: string;
    sender: string;
    role?: string;
    avatar: string;
    avatarColor: string;
    text: string;
    time: string;
    isMe: boolean;
  };

  const messages: Msg[] = [
    { id: "1", sender: "Hiver", role: "Admin", avatar: "H", avatarColor: "bg-primary", text: "Welcome everyone to the HiverLMS Group Chat! This is your live trading desk floor. Discuss charts, option chains, breakouts, and general market setups.", time: "10:30 AM", isMe: false },
    { id: "2", sender: "Prakash Nayak", role: "Trader", avatar: "PN", avatarColor: "bg-emerald-500", text: "Nifty options open interest shows strong put writing defending the 22,000 zone. Breakout targets look solid around 22,120 index level. Anyone in call options?", time: "10:32 AM", isMe: false },
    { id: "3", sender: "Amber Bull", avatar: "AB", avatarColor: "bg-amber-500", text: "Already in! Bought 22,000 CE calls during the morning dip. Volume pattern on the 15-minute timeframe is verifying strong bullish continuation.", time: "10:35 AM", isMe: false },
    { id: "4", sender: "Emerald Bear", avatar: "EB", avatarColor: "bg-teal-500", text: "Nice entry. Deciding to sell weekly options straddles. Premium decay is looking premium today.", time: "10:39 AM", isMe: false }
  ];

  // Fetch active user session
  async function loadUser() {
    try {
      const { data: session } = await authClient.getSession();
      if (session?.user) {
        myName = session.user.name || "Hiver";
        myInitials = myName.split(" ").map(n => n[0]).join("").toUpperCase();

        // Retrieve current avatar theme color to match settings
        const currentTheme = localStorage.getItem("profile-avatar-theme") || "default";
        if (currentTheme === "emerald") {
          avatarColorClass = "bg-gradient-to-br from-emerald-400 to-teal-500";
        } else if (currentTheme === "blue") {
          avatarColorClass = "bg-gradient-to-br from-blue-400 to-indigo-500";
        } else if (currentTheme === "indigo") {
          avatarColorClass = "bg-gradient-to-br from-indigo-400 to-purple-500";
        } else if (currentTheme === "rose") {
          avatarColorClass = "bg-gradient-to-br from-rose-400 to-pink-500";
        } else {
          avatarColorClass = "bg-primary";
        }

        // Update UI panels for our my-user footer
        const myAvatars = document.querySelectorAll(".chat-my-avatar");
        myAvatars.forEach(el => {
          el.className = `chat-my-avatar w-9 h-9 rounded-full text-white font-bold text-xs flex items-center justify-center shrink-0 border border-primary/25 shadow-xs select-none ${avatarColorClass}`;
          el.textContent = myInitials;
        });
      }
    } catch (e) {
      console.error(e);
    }
  }

  // Draw message stream optimized for text readability
  function renderMessages() {
    msgContainer.innerHTML = "";

    if (messages.length === 0) {
      msgContainer.innerHTML = `
        <div class="h-full flex items-center justify-center text-center p-6 select-none">
          <div class="space-y-1.5">
            <p class="text-base font-bold text-muted-foreground">No messages yet</p>
            <p class="text-xs text-muted-foreground/60 leading-normal font-medium">Type a message to kick off the group chat conversation!</p>
          </div>
        </div>
      `;
      return;
    }

    messages.forEach(msg => {
      const isMe = msg.isMe;
      const cardHtml = isMe
        ? `
          <div class="flex gap-3.5 items-end justify-end ml-16 animate-slide-up">
            <div class="flex flex-col gap-1.5 items-end max-w-xl md:max-w-2xl">
              <div class="flex items-baseline gap-2">
                <span class="text-[9px] text-muted-foreground/50 font-bold">${msg.time}</span>
                <span class="text-xs font-bold text-foreground">You</span>
              </div>
              <div class="px-4.5 py-3 rounded-2xl rounded-tr-none bg-primary text-primary-foreground text-sm font-semibold leading-relaxed shadow-xs whitespace-pre-wrap select-text">
                ${msg.text}
              </div>
            </div>
            <div class="w-8 h-8 rounded-full ${msg.avatarColor} text-white text-[10px] font-bold flex items-center justify-center border border-primary/20 shadow-xs select-none shrink-0">${msg.avatar}</div>
          </div>
        `
        : `
          <div class="flex gap-3.5 items-start mr-16 animate-slide-up">
            <div class="w-8 h-8 rounded-full ${msg.avatarColor} text-white text-[10px] font-bold flex items-center justify-center border border-primary/20 shadow-xs select-none shrink-0">${msg.avatar}</div>
            <div class="flex flex-col gap-1.5 max-w-xl md:max-w-2xl">
              <div class="flex items-baseline gap-2">
                <span class="text-xs font-bold text-foreground">${msg.sender}</span>
                ${msg.role ? `<span class="px-1.5 py-0.2 bg-primary/10 text-primary text-[6px] font-extrabold rounded uppercase leading-none border border-primary/10">${msg.role}</span>` : ""}
                <span class="text-[9px] text-muted-foreground/50 font-bold">${msg.time}</span>
              </div>
              <div class="px-4.5 py-3 rounded-2xl rounded-tl-none bg-muted/30 border border-border/40 text-foreground text-sm font-semibold leading-relaxed shadow-3xs whitespace-pre-wrap select-text">
                ${msg.text}
              </div>
            </div>
          </div>
        `;

      msgContainer.insertAdjacentHTML("beforeend", cardHtml);
    });

    // Auto scroll bottom
    msgContainer.scrollTop = msgContainer.scrollHeight;
  }

  // Handle send message
  inputForm.addEventListener("submit", (e) => {
    e.preventDefault();
    const text = msgInput.value.trim();
    if (!text) return;

    const newMsg: Msg = {
      id: Date.now().toString(),
      sender: myName,
      avatar: myInitials,
      avatarColor: avatarColorClass,
      text,
      time: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
      isMe: true
    };

    messages.push(newMsg);
    msgInput.value = "";
    renderMessages();
  });

  // Quick trade emoji tray listener
  const emojiBtns = document.querySelectorAll(".quick-emoji-btn") as NodeListOf<HTMLButtonElement>;
  emojiBtns.forEach(btn => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      const emoji = btn.getAttribute("data-emoji")!;
      msgInput.value += (msgInput.value ? " " : "") + emoji;
      msgInput.focus();
    });
  });

  // Clear Chat history action
  clearBtn.addEventListener("click", () => {
    messages.length = 0;
    renderMessages();
    toast.success("Chat history cleared.");
  });

  // Real-time Group Chat Simulation (Receives trading signals/tips from mock members over time)
  const simulatedComments = [
    { sender: "Amber Bull", avatar: "AB", avatarColor: "bg-amber-500", text: "Reliance is breaking out of its range! Solid bull candles on high volume. This should easily drag Nifty above 22,050." },
    { sender: "Prakash Nayak", role: "Trader", avatar: "PN", avatarColor: "bg-emerald-500", text: "Closed remaining CE calls at +40%! Spectacular morning move. Taking a break now to avoid overtrading." },
    { sender: "Emerald Bear", avatar: "EB", avatarColor: "bg-teal-500", text: "Just closed my straddles. Decay was massive in the first hour. Decent green profits today." },
    { sender: "Rose Scalp", avatar: "RS", avatarColor: "bg-rose-500", text: "Look at the 15-minute chart of Nifty. Clean bull flag breakout. Targets are fully aligned for another leg up." },
    { sender: "Sapphire", avatar: "ST", avatarColor: "bg-blue-500", text: "Open interest shows 22,100 has huge call writing. Unlikely to cross 22,100 in this session. Be cautious on longs there." }
  ];

  function startChatSimulation() {
    setInterval(() => {
      const chatView = document.getElementById("view-chat")!;
      // Only simulate if chat view is active/visible
      if (chatView.classList.contains("hidden")) return;

      // Pick a random comment
      const comment = simulatedComments[Math.floor(Math.random() * simulatedComments.length)];
      
      const newMsg = {
        id: Date.now().toString(),
        sender: comment.sender,
        role: (comment as any).role,
        avatar: comment.avatar,
        avatarColor: comment.avatarColor,
        text: comment.text,
        time: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
        isMe: false
      };

      // Append simulation message
      if (messages.length > 25) {
        messages.shift();
      }
      messages.push(newMsg);
      renderMessages();
    }, 20000); // simulation sends message every 20 seconds
  }

  // Run on dashboard navigation triggers to sync details
  const chatNavBtn = document.getElementById("nav-chat");
  if (chatNavBtn) {
    chatNavBtn.addEventListener("click", () => {
      loadUser();
      renderMessages();
    });
  }

  // Load initially
  loadUser();
  renderMessages();
  startChatSimulation();
</script>