---
// BlogPostsView Component
---
<!-- Blog Posts List View -->
<div id="view-blog-posts" class="hidden mt-6 space-y-4">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
    <div class="flex items-center gap-3">
      <div class="relative inline-block text-left" id="dropdown-status-container">
        <button type="button" id="btn-status-dropdown" class="flex items-center justify-between gap-1.5 px-3.5 py-2 text-sm bg-card border border-border rounded-sm text-foreground font-semibold focus:outline-hidden shadow-3xs hover:bg-muted/50 cursor-pointer min-w-[130px]">
          <span id="selected-status-label">All Status</span>
          <svg class="w-4 h-4 opacity-50 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
        </button>
        <div id="dropdown-status-menu" class="absolute left-0 mt-1.5 w-44 bg-card border border-border rounded-sm shadow-md py-1 hidden z-50 animate-fade-in scale-95 opacity-0 transition-all origin-top-left">
          <button type="button" class="w-full text-left px-3.5 py-2.5 text-sm hover:bg-muted font-semibold text-foreground transition-colors flex items-center justify-between cursor-pointer status-option" data-value="all">
            <span>All Status</span>
            <svg class="w-3.5 h-3.5 text-primary check-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          </button>
          <button type="button" class="w-full text-left px-3.5 py-2.5 text-sm hover:bg-muted font-semibold text-foreground transition-colors flex items-center justify-between cursor-pointer status-option" data-value="published">
            <span>Published</span>
            <svg class="w-3.5 h-3.5 text-primary check-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          </button>
          <button type="button" class="w-full text-left px-3.5 py-2.5 text-sm hover:bg-muted font-semibold text-foreground transition-colors flex items-center justify-between cursor-pointer status-option" data-value="draft">
            <span>Drafts</span>
            <svg class="w-3.5 h-3.5 text-primary check-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          </button>
          <button type="button" class="w-full text-left px-3.5 py-2.5 text-sm hover:bg-muted font-semibold text-foreground transition-colors flex items-center justify-between cursor-pointer status-option" data-value="trash">
            <span>Trash</span>
            <svg class="w-3.5 h-3.5 text-primary check-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          </button>
        </div>
      </div>
      <button type="button" id="btn-status-trash" class="flex items-center justify-center gap-1.5 px-3.5 py-2 text-sm bg-card border border-border rounded-sm text-foreground font-semibold hover:bg-muted/50 cursor-pointer transition-colors shadow-3xs" title="View Trash">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-destructive/75"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
        <span>Trash</span>
      </button>
    </div>
    <div class="flex items-center gap-3">
      <input type="text" id="blog-search" placeholder="Search posts..." class="px-3.5 py-2 text-sm bg-card border border-border rounded-sm text-foreground focus:outline-hidden focus:ring-1 focus:ring-primary w-64 placeholder:text-muted-foreground/75 shadow-3xs" />
      <button id="btn-new-post" class="flex items-center justify-center gap-1.5 px-4 py-2 rounded-sm bg-primary text-primary-foreground hover:bg-primary/95 text-sm font-bold transition-all shadow-md cursor-pointer select-none">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        New Post
      </button>
    </div>
  </div>

  <div class="bg-card border border-border rounded-sm overflow-hidden shadow-2xs">
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-left text-sm">
        <thead class="bg-muted/30 border-b border-border text-xs font-semibold text-muted-foreground/90 uppercase tracking-wider">
          <tr>
            <th class="p-4">Title</th>
            <th class="p-4">Category</th>
            <th class="p-4">Tags</th>
            <th class="p-4">Status</th>
            <th class="p-4">Published Date</th>
            <th class="p-4">Last Updated</th>
            <th class="p-4 text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="posts-table-body" class="divide-y divide-border">
          <tr>
            <td colspan="7" class="p-8 text-center text-muted-foreground font-medium text-sm">Loading posts...</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Pagination Controls -->
    <div class="flex items-center justify-between px-4 py-3 border-t border-border bg-card select-none" id="posts-pagination">
      <div class="text-sm text-muted-foreground">
        Showing <span id="pagination-start" class="font-medium text-foreground">0</span> to <span id="pagination-end" class="font-medium text-foreground">0</span> of <span id="pagination-total" class="font-medium text-foreground">0</span> posts
      </div>
      <div class="flex items-center gap-2">
        <button type="button" id="btn-posts-prev" class="px-3.5 py-1.5 text-sm bg-card border border-border rounded-sm text-foreground font-semibold hover:bg-muted/50 disabled:opacity-50 disabled:pointer-events-none cursor-pointer transition-colors shadow-3xs">
          Previous
        </button>
        <button type="button" id="btn-posts-next" class="px-3.5 py-1.5 text-sm bg-card border border-border rounded-sm text-foreground font-semibold hover:bg-muted/50 disabled:opacity-50 disabled:pointer-events-none cursor-pointer transition-colors shadow-3xs">
          Next
        </button>
      </div>
    </div>
  </div>
</div>
