---
// BlogCategoriesView Component
---
<!-- Blog Categories View -->
<div id="view-blog-categories" class="hidden mt-6 grid gap-6 lg:grid-cols-3">
  <!-- Add Category form -->
  <div class="bg-card border border-border rounded-sm p-5 shadow-2xs space-y-4 h-fit">
    <div>
      <h3 class="font-bold text-sm text-foreground">Add New Category</h3>
      <p class="text-xs text-muted-foreground mt-1">Organize articles into distinct categories.</p>
    </div>
    <form id="category-form" class="space-y-4">
      <div class="space-y-1.5">
        <label for="category-name" class="text-[10px] font-bold text-muted-foreground uppercase tracking-wider">Name</label>
        <input type="text" id="category-name" placeholder="e.g. Trading Basics" required class="w-full px-3 py-2 text-xs bg-card border border-border rounded-sm focus:ring-1 focus:ring-primary focus:outline-hidden text-foreground font-medium placeholder:text-muted-foreground/75" />
      </div>
      <div class="space-y-1.5">
        <label for="category-slug" class="text-[10px] font-bold text-muted-foreground uppercase tracking-wider">Slug</label>
        <input type="text" id="category-slug" placeholder="e.g. trading-basics" required class="w-full px-3 py-2 text-xs bg-card border border-border rounded-sm focus:ring-1 focus:ring-primary focus:outline-hidden text-foreground font-medium placeholder:text-muted-foreground/75" />
      </div>
      <button type="submit" class="w-full py-2 bg-primary text-primary-foreground hover:bg-primary/95 text-xs font-bold rounded-sm transition-colors cursor-pointer shadow-sm font-semibold">
        Add Category
      </button>
    </form>
  </div>

  <!-- Categories List -->
  <div class="lg:col-span-2 bg-card border border-border rounded-sm overflow-hidden shadow-xs h-fit">
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-left text-xs">
        <thead class="bg-muted/30 border-b border-border text-[11px] font-semibold text-muted-foreground/90 uppercase tracking-wider">
          <tr>
            <th class="p-4">Name</th>
            <th class="p-4">Slug</th>
            <th class="p-4">Posts Count</th>
            <th class="p-4 text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="categories-table-body" class="divide-y divide-border">
          <tr>
            <td colspan="4" class="p-8 text-center text-muted-foreground font-medium">Loading categories...</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
