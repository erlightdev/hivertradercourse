---
// BlogEditorView Component
---
<!-- Blog Post Editor View -->
<div id="view-blog-editor" class="hidden mt-6 space-y-6">
  <div class="flex items-center justify-between border-b border-border/40 pb-4">
    <div class="flex items-center gap-3">
      <button id="btn-editor-back" class="p-2 hover:bg-muted border border-border rounded-sm text-muted-foreground hover:text-foreground transition-all cursor-pointer">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <div>
        <h2 id="editor-view-title" class="text-lg font-bold text-foreground">Create New Post</h2>
        <p class="text-xs text-muted-foreground">Draft or publish a sleek article using the Tiptap editor.</p>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <button id="btn-editor-seo" type="button" class="flex items-center gap-1.5 px-4 py-2 hover:bg-muted text-sm font-semibold rounded-sm border border-border transition-all cursor-pointer text-muted-foreground hover:text-foreground">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        SEO
      </button>
      <button id="btn-editor-cancel" class="px-4 py-2 hover:bg-muted text-sm font-semibold rounded-sm border border-border transition-all cursor-pointer text-muted-foreground hover:text-foreground">
        Cancel
      </button>
      <button id="btn-editor-save" class="px-5 py-2 hover:bg-muted text-sm font-semibold rounded-sm border border-border transition-all cursor-pointer text-muted-foreground hover:text-foreground">
        Save Post
      </button>
      <button id="btn-editor-publish" class="px-5 py-2 bg-primary text-primary-foreground hover:bg-primary/95 text-sm font-bold rounded-sm transition-all cursor-pointer shadow-sm">
        Publish
      </button>
    </div>
  </div>

  <div class="space-y-5">
    <!-- Post Title -->
    <div class="space-y-1.5">
      <label for="post-title-input" class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Post Title</label>
      <input type="text" id="post-title-input" placeholder="Enter post title..." required class="w-full px-4 py-2.5 text-sm bg-card border border-border rounded-sm focus:ring-1 focus:ring-primary focus:outline-hidden text-foreground font-semibold placeholder:text-muted-foreground/80 shadow-2xs" />
      <div class="flex items-center gap-1.5 text-xs text-muted-foreground/90 font-medium pl-1 select-none mt-1">
        <span>URL Preview:</span>
        <a href="#" id="post-slug-preview-link" target="_blank" class="text-primary hover:underline font-mono truncate max-w-lg">/blog/</a>
      </div>
    </div>

    <!-- Post Settings (full-width, between title and content editor) -->
    <div class="p-5 bg-card border border-border rounded-sm shadow-2xs space-y-4">
      <h3 class="font-bold text-xs text-foreground uppercase tracking-wider pb-2 border-b border-border/40">Post Settings</h3>

      <div class="grid gap-4 sm:grid-cols-2">
        <!-- URL Slug -->
        <div class="space-y-1.5">
          <label for="post-slug-input" class="text-xs font-bold text-muted-foreground uppercase tracking-wider">URL Slug</label>
          <input type="text" id="post-slug-input" placeholder="url-slug" class="w-full px-3 py-2.5 text-sm bg-card border border-border rounded-sm focus:ring-1 focus:ring-primary focus:outline-hidden text-foreground font-medium placeholder:text-muted-foreground/80" />
        </div>

        <!-- Author -->
        <div class="space-y-1.5">
          <label for="post-author-select" class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Author</label>
          <select id="post-author-select" class="w-full px-3 py-2.5 text-sm bg-card border border-border rounded-sm focus:ring-1 focus:ring-primary focus:outline-hidden text-foreground font-medium cursor-pointer">
            <option value="">Loading authors…</option>
          </select>
        </div>

        <!-- Category -->
        <div class="space-y-1.5">
          <label class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Category</label>
          <div class="relative" id="dropdown-category-container">
            <button type="button" id="btn-category-dropdown" class="flex items-center justify-between gap-1.5 w-full px-3.5 py-2.5 text-sm bg-card border border-border rounded-sm text-foreground font-medium focus:ring-1 focus:ring-primary focus:outline-hidden shadow-3xs hover:bg-muted/40 cursor-pointer transition-colors">
              <span id="selected-categories-label" class="truncate text-muted-foreground">Select categories</span>
              <svg id="chevron-category" class="w-4 h-4 shrink-0 opacity-50 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
            </button>
            <div id="dropdown-category-menu" class="dropdown-menu absolute left-0 mt-1.5 w-full min-w-[14rem] bg-popover border border-border rounded-lg shadow-lg py-1.5 hidden z-50 max-h-56 overflow-y-auto">
              <span class="block px-3 py-2 text-xs text-muted-foreground font-semibold">No categories available</span>
            </div>
          </div>
          <div id="selected-categories-chips" class="hidden flex-wrap gap-1.5 pt-0.5"></div>
        </div>

        <!-- Tags -->
        <div class="space-y-1.5">
          <label class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Tags</label>
          <div class="relative" id="dropdown-tags-container">
            <button type="button" id="btn-tags-dropdown" class="flex items-center justify-between gap-1.5 w-full px-3.5 py-2.5 text-sm bg-card border border-border rounded-sm text-foreground font-medium focus:ring-1 focus:ring-primary focus:outline-hidden shadow-3xs hover:bg-muted/40 cursor-pointer transition-colors">
              <span id="selected-tags-label" class="truncate text-muted-foreground">Select tags</span>
              <svg id="chevron-tags" class="w-4 h-4 shrink-0 opacity-50 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
            </button>
            <div id="dropdown-tags-menu" class="dropdown-menu absolute left-0 mt-1.5 w-full min-w-[14rem] bg-popover border border-border rounded-lg shadow-lg py-1.5 hidden z-50 max-h-56 overflow-y-auto">
              <span class="block px-3 py-2 text-xs text-muted-foreground font-semibold">No tags available</span>
            </div>
          </div>
          <div id="selected-tags-chips" class="hidden flex-wrap gap-1.5 pt-0.5"></div>
        </div>
      </div>

      <div class="flex flex-wrap items-center justify-between gap-4 pt-3 border-t border-border/40">
        <div class="flex items-center gap-3">
          <span class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Published Status</span>
          <label class="relative inline-flex items-center cursor-pointer select-none">
            <input type="checkbox" id="post-published-checkbox" class="sr-only peer" />
            <div class="w-9 h-5 bg-muted peer-focus:outline-hidden rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-muted/30 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
          </label>
        </div>

        <div id="post-dates-container" class="hidden flex flex-wrap gap-x-8 gap-y-1.5 select-none">
          <div class="flex items-center gap-2 text-xs text-muted-foreground font-semibold">
            <span class="uppercase tracking-wider">Created</span>
            <span id="post-created-date" class="font-mono text-xs text-foreground"></span>
          </div>
          <div class="flex items-center gap-2 text-xs text-muted-foreground font-semibold">
            <span class="uppercase tracking-wider">Last Updated</span>
            <span id="post-updated-date" class="font-mono text-[10px] text-foreground"></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Tiptap Editor Container -->
    <div class="space-y-1.5">
      <label class="text-xs font-bold text-muted-foreground uppercase tracking-wider font-sans">Content Editor</label>
      <div class="border border-border rounded-sm bg-card overflow-hidden flex flex-col focus-within:ring-1 focus-within:ring-primary min-h-[400px] shadow-2xs">
        <!-- Editor Toolbar -->
        <div class="flex flex-wrap items-center gap-0.5 p-2 bg-muted/20 border-b border-border select-none sticky top-0 z-10" id="editor-toolbar">
          <!-- History -->
          <button type="button" data-cmd="undo" title="Undo" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"/><path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"/></svg>
          </button>
          <button type="button" data-cmd="redo" title="Redo" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 7v6h-6"/><path d="M3 17a9 9 0 0 1 9-9 9 9 0 0 1 6 2.3l3 2.7"/></svg>
          </button>
          <div class="h-5 w-px bg-border mx-1.5"></div>

          <!-- Headings -->
          <button type="button" data-cmd="h1" title="Heading 1" class="toolbar-btn h-8 px-2 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer text-xs font-extrabold">H1</button>
          <button type="button" data-cmd="h2" title="Heading 2" class="toolbar-btn h-8 px-2 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer text-xs font-bold">H2</button>
          <button type="button" data-cmd="h3" title="Heading 3" class="toolbar-btn h-8 px-2 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer text-xs font-semibold">H3</button>
          <div class="h-5 w-px bg-border mx-1.5"></div>

          <!-- Lists & blocks -->
          <button type="button" data-cmd="bulletList" title="Bullet List" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" x2="21" y1="6" y2="6"/><line x1="8" x2="21" y1="12" y2="12"/><line x1="8" x2="21" y1="18" y2="18"/><line x1="3" x2="3.01" y1="6" y2="6"/><line x1="3" x2="3.01" y1="12" y2="12"/><line x1="3" x2="3.01" y1="18" y2="18"/></svg>
          </button>
          <button type="button" data-cmd="orderedList" title="Numbered List" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="10" x2="21" y1="6" y2="6"/><line x1="10" x2="21" y1="12" y2="12"/><line x1="10" x2="21" y1="18" y2="18"/><path d="M4 6h1v4"/><path d="M4 10h2"/><path d="M6 18H4c0-1 2-2 2-3s-1-1.5-2-1"/></svg>
          </button>
          <button type="button" data-cmd="blockquote" title="Quote" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 6H3"/><path d="M21 12H8"/><path d="M21 18H8"/><path d="M3 12v6"/></svg>
          </button>
          <button type="button" data-cmd="codeBlock" title="Code Block" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </button>
          <div class="h-5 w-px bg-border mx-1.5"></div>

          <!-- Marks -->
          <button type="button" data-cmd="bold" title="Bold" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer text-sm font-bold">B</button>
          <button type="button" data-cmd="italic" title="Italic" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer text-sm italic font-serif">I</button>
          <button type="button" data-cmd="strike" title="Strikethrough" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer text-sm line-through">S</button>
          <button type="button" data-cmd="underline" title="Underline" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer text-sm underline underline-offset-2">U</button>
          <button type="button" data-cmd="highlight" title="Highlight" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11-6 6v3h9l3-3"/><path d="m22 12-4.6 4.6a2 2 0 0 1-2.8 0l-5.2-5.2a2 2 0 0 1 0-2.8L14 4"/></svg>
          </button>
          <button type="button" data-cmd="link" title="Link" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          </button>
          <div class="h-5 w-px bg-border mx-1.5"></div>

          <!-- Super / Subscript -->
          <button type="button" data-cmd="superscript" title="Superscript" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m4 19 8-8"/><path d="m12 19-8-8"/><path d="M20 12h-4c0-1.5.44-2 1.5-2.5S20 8.334 20 7c0-.472-.291-.903-.674-1.182C18.586 5.4 18 5.286 17.5 5.5c-.4.172-.6.6-.6 1"/></svg>
          </button>
          <button type="button" data-cmd="subscript" title="Subscript" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m4 5 8 8"/><path d="m12 5-8 8"/><path d="M20 19h-4c0-1.5.44-2 1.5-2.5S20 15.334 20 14c0-.472-.291-.903-.674-1.182C18.586 12.4 18 12.286 17.5 12.5c-.4.172-.6.6-.6 1"/></svg>
          </button>
          <div class="h-5 w-px bg-border mx-1.5"></div>

          <!-- Alignment -->
          <button type="button" data-cmd="alignLeft" title="Align Left" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" x2="3" y1="6" y2="6"/><line x1="15" x2="3" y1="12" y2="12"/><line x1="17" x2="3" y1="18" y2="18"/></svg>
          </button>
          <button type="button" data-cmd="alignCenter" title="Align Center" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" x2="3" y1="6" y2="6"/><line x1="17" x2="7" y1="12" y2="12"/><line x1="19" x2="5" y1="18" y2="18"/></svg>
          </button>
          <button type="button" data-cmd="alignRight" title="Align Right" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" x2="3" y1="6" y2="6"/><line x1="21" x2="9" y1="12" y2="12"/><line x1="21" x2="7" y1="18" y2="18"/></svg>
          </button>
          <button type="button" data-cmd="alignJustify" title="Justify" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="21" y1="12" y2="12"/><line x1="3" x2="21" y1="18" y2="18"/></svg>
          </button>

          <div class="flex-1"></div>

          <!-- Insert / Add block -->
          <button type="button" data-cmd="image" title="Insert Image" class="toolbar-btn w-8 h-8 flex items-center justify-center hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
          </button>
          <button type="button" data-cmd="slash" title="Add block (or type /)" class="toolbar-btn h-8 px-2.5 flex items-center gap-1.5 hover:bg-muted rounded-md border border-border text-foreground font-semibold transition-all cursor-pointer text-xs">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            Add
          </button>
        </div>
        <!-- Editor Content Area -->
        <div class="flex-1 py-5 pl-12 pr-5 overflow-y-auto outline-hidden min-h-[360px] max-h-[600px]" id="editor-content-tiptap"></div>
      </div>
    </div>
  </div>
</div>
