---
// CoursesView Component
---
<div id="view-courses" class="hidden w-full h-full flex flex-col overflow-hidden bg-background">
  <!-- 1. COURSE LIST PANEL -->
  <div id="courses-list-panel" class="flex-1 flex flex-col overflow-hidden p-6">


    <!-- Empty State -->
    <div id="courses-empty-state" class="hidden flex-1 flex flex-col items-center justify-center border border-dashed border-border/60 rounded-xl p-8 text-center max-w-lg mx-auto my-12 bg-muted/5">
      <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary mb-4">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
      </div>
      <h3 class="font-bold text-sm text-foreground">No courses found</h3>
      <p class="text-xs text-muted-foreground mt-1.5 max-w-xs leading-normal">
        Get started by creating your first course. You can structure it into chapters and lessons later.
      </p>
      <button id="courses-empty-create-btn" class="mt-4 px-4 py-2 bg-primary text-primary-foreground hover:bg-primary/90 font-bold text-xs rounded-lg transition-colors cursor-pointer select-none">
        Create Your First Course
      </button>
    </div>

    <!-- Courses Grid -->
    <div id="courses-grid" class="flex-1 overflow-y-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 content-start gap-6 pb-6 hidden">
      <!-- Course cards will be injected dynamically -->
    </div>
  </div>

  <!-- 2. CURRICULUM BUILDER PANEL -->
  <div id="courses-builder-panel" class="hidden flex-1 flex flex-col overflow-hidden">
    <div class="h-16 flex items-center justify-between px-6 border-b border-border/40 shrink-0">
      <div class="flex items-center gap-3">
        <button id="builder-back-btn" class="p-2 hover:bg-muted text-muted-foreground hover:text-foreground rounded-lg transition-colors cursor-pointer" aria-label="Back to courses">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
        </button>
        <div>
          <h3 id="builder-course-title" class="font-bold text-sm text-foreground">Loading Course...</h3>
          <p class="text-[10px] text-muted-foreground uppercase tracking-widest mt-0.5" id="builder-course-category">Category</p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <span id="builder-course-status-badge" class="px-2 py-0.5 rounded-full text-[9px] font-bold border">DRAFT</span>
      </div>
    </div>

    <!-- Split Layout Content -->
    <div class="flex-1 flex overflow-hidden">
      <!-- Left side: Course Details Forms -->
      <div class="w-80 border-r border-border/40 p-5 overflow-y-auto shrink-0 space-y-6">
        <h4 class="text-xs font-bold text-foreground uppercase tracking-wider">Course Settings</h4>
        
        <form id="builder-course-form" class="space-y-4">
          <div class="space-y-1.5">
            <label class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider block">Course Title</label>
            <input type="text" id="builder-title-input" class="w-full px-3 py-2 text-xs bg-muted/20 border border-border rounded-lg focus:outline-hidden text-foreground font-medium" required />
          </div>

          <div class="space-y-1.5">
            <label class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider block">Slug</label>
            <input type="text" id="builder-slug-input" class="w-full px-3 py-2 text-xs bg-muted/20 border border-border rounded-lg focus:outline-hidden text-foreground font-medium" required />
          </div>

          <div class="space-y-1.5">
            <label class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider block">Small Description</label>
            <textarea id="builder-smalldesc-input" rows="2" class="w-full px-3 py-2 text-xs bg-muted/20 border border-border rounded-lg focus:outline-hidden text-foreground font-medium resize-none" required></textarea>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label id="builder-price-label" class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider block">Price (USD)</label>
              <input type="number" id="builder-price-input" min="0" step="0.01" class="w-full px-3 py-2 text-xs bg-muted/20 border border-border rounded-lg focus:outline-hidden text-foreground font-medium" required />
            </div>
            <div class="space-y-1.5">
              <label class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider block">Duration (Hours)</label>
              <input type="number" id="builder-duration-input" min="1" class="w-full px-3 py-2 text-xs bg-muted/20 border border-border rounded-lg focus:outline-hidden text-foreground font-medium" required />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider block">Level</label>
              <select id="builder-level-input" class="w-full px-3 py-2 text-xs bg-card border border-border rounded-lg focus:outline-hidden text-foreground font-medium">
                <option value="BEGINNER">Beginner</option>
                <option value="INTERMEDIATE">Intermediate</option>
                <option value="ADVANCED">Advanced</option>
              </select>
            </div>
            <div class="space-y-1.5">
              <label class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider block">Status</label>
              <select id="builder-status-input" class="w-full px-3 py-2 text-xs bg-card border border-border rounded-lg focus:outline-hidden text-foreground font-medium">
                <option value="DRAFT">Draft</option>
                <option value="PUBLISHED">Published</option>
                <option value="ARCHIVED">Archived</option>
              </select>
            </div>
          </div>

          <div class="space-y-1.5">
            <label class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider block">Category</label>
            <input type="text" id="builder-category-input" class="w-full px-3 py-2 text-xs bg-muted/20 border border-border rounded-lg focus:outline-hidden text-foreground font-medium" required />
          </div>

          <!-- Thumbnail Upload Widget -->
          <div class="space-y-2">
            <label class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider block">Course Thumbnail</label>
            <div class="border border-border/80 rounded-lg p-3 bg-muted/5 space-y-3">
              <div id="builder-thumb-preview" class="w-full h-24 bg-muted/20 rounded-md flex items-center justify-center text-muted-foreground overflow-hidden">
                <span class="text-[10px]">No thumbnail uploaded</span>
              </div>
              <input type="file" id="builder-thumb-file-input" accept="image/*" class="hidden" />
              <div class="flex gap-2">
                <button type="button" id="builder-thumb-upload-btn" class="flex-1 py-1.5 bg-muted hover:bg-muted/80 text-[10px] font-bold border border-border rounded-md transition-colors cursor-pointer text-center select-none">
                  Choose Image
                </button>
              </div>
              <!-- Progress Bar -->
              <div id="builder-thumb-progress-container" class="space-y-1 hidden">
                <div class="flex items-center justify-between text-[9px] font-bold">
                  <span class="text-primary animate-pulse">Uploading...</span>
                  <span id="builder-thumb-progress-text">0%</span>
                </div>
                <div class="w-full h-1.5 bg-muted rounded-full overflow-hidden">
                  <div id="builder-thumb-progress-bar" class="h-full bg-primary transition-all duration-150" style="width: 0%"></div>
                </div>
              </div>
            </div>
          </div>

          <button type="submit" class="w-full py-2 bg-primary text-primary-foreground hover:bg-primary/95 font-bold text-xs rounded-lg transition-colors cursor-pointer shadow-xs select-none">
            Save Course Info
          </button>
        </form>
      </div>

      <!-- Right side: Chapters and Lessons curriculum structure builder -->
      <div class="flex-1 flex flex-col overflow-hidden p-6 bg-muted/5">
        <div class="flex items-center justify-between mb-4">
          <h4 class="text-xs font-bold text-foreground uppercase tracking-wider">Curriculum Structure</h4>
          <button id="builder-add-chapter-btn" class="px-3 py-1.5 bg-muted border border-border hover:bg-muted/80 text-foreground font-bold text-xs rounded-lg transition-colors cursor-pointer select-none">
            + Add Chapter
          </button>
        </div>

        <!-- Chapters List -->
        <div id="builder-chapters-container" class="flex-1 overflow-y-auto space-y-4 pb-6">
          <!-- Chapters and lessons dynamically injected -->
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 3. LESSON DETAILS MODAL -->
<div id="lesson-modal-overlay" class="fixed inset-0 z-[110] bg-background/80 backdrop-blur-xs hidden justify-center items-center p-4">
  <div id="lesson-modal-content" class="relative w-full max-w-lg bg-card text-card-foreground border border-border rounded-xl shadow-2xl p-5 scale-95 opacity-0 transition-all duration-200 ease-out flex flex-col max-h-[90vh] overflow-hidden">
    <div class="flex items-center justify-between border-b border-border/40 pb-3 mb-4 shrink-0">
      <h3 class="font-bold text-sm text-foreground">Edit Lesson Details</h3>
      <button id="lesson-modal-close" class="p-1.5 hover:bg-muted rounded-md text-muted-foreground hover:text-foreground transition-all cursor-pointer" type="button">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <form id="lesson-modal-form" class="space-y-4 flex-1 overflow-y-auto pr-1">
      <div class="space-y-1.5">
        <label class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider block">Lesson Title</label>
        <input type="text" id="lesson-title-input" class="w-full px-3 py-2 text-xs bg-muted/20 border border-border rounded-lg focus:outline-hidden text-foreground font-medium" required />
      </div>

      <div class="space-y-1.5">
        <label class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider block">Description / Notes</label>
        <textarea id="lesson-description-input" rows="4" class="w-full px-3 py-2 text-xs bg-muted/20 border border-border rounded-lg focus:outline-hidden text-foreground font-medium resize-y" placeholder="Summarize the core topics covered in this lesson..."></textarea>
      </div>

      <!-- Media Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Lesson Video Widget -->
        <div class="space-y-1.5">
          <label class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider block">Lesson Video</label>
          <div class="border border-border/80 rounded-lg p-3 bg-muted/5 space-y-3">
            <div id="lesson-video-status" class="text-[10px] text-muted-foreground text-center py-4 border border-dashed border-border rounded-md bg-muted/10">
              No video uploaded
            </div>
            <input type="file" id="lesson-video-file-input" accept="video/*" class="hidden" />
            <button type="button" id="lesson-video-upload-btn" class="w-full py-1.5 bg-muted hover:bg-muted/80 text-[10px] font-bold border border-border rounded-md transition-colors cursor-pointer text-center select-none">
              Choose Video
            </button>
            
            <!-- Progress Bar -->
            <div id="lesson-video-progress-container" class="space-y-1 hidden">
              <div class="flex items-center justify-between text-[9px] font-bold">
                <span class="text-primary animate-pulse">Uploading Video...</span>
                <span id="lesson-video-progress-text">0%</span>
              </div>
              <div class="w-full h-1.5 bg-muted rounded-full overflow-hidden">
                <div id="lesson-video-progress-bar" class="h-full bg-primary transition-all duration-150" style="width: 0%"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Lesson Thumbnail Widget -->
        <div class="space-y-1.5">
          <label class="text-[9px] font-bold text-muted-foreground uppercase tracking-wider block">Lesson Thumbnail (Optional)</label>
          <div class="border border-border/80 rounded-lg p-3 bg-muted/5 space-y-3">
            <div id="lesson-thumb-preview" class="w-full h-16 bg-muted/20 rounded-md flex items-center justify-center text-muted-foreground overflow-hidden">
              <span class="text-[9px]">No thumbnail</span>
            </div>
            <input type="file" id="lesson-thumb-file-input" accept="image/*" class="hidden" />
            <button type="button" id="lesson-thumb-upload-btn" class="w-full py-1.5 bg-muted hover:bg-muted/80 text-[10px] font-bold border border-border rounded-md transition-colors cursor-pointer text-center select-none">
              Choose Image
            </button>

            <!-- Progress Bar -->
            <div id="lesson-thumb-progress-container" class="space-y-1 hidden">
              <div class="flex items-center justify-between text-[9px] font-bold">
                <span class="text-primary animate-pulse">Uploading...</span>
                <span id="lesson-thumb-progress-text">0%</span>
              </div>
              <div class="w-full h-1.5 bg-muted rounded-full overflow-hidden">
                <div id="lesson-thumb-progress-bar" class="h-full bg-primary transition-all duration-150" style="width: 0%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="flex justify-end gap-2 pt-3 border-t border-border/40 shrink-0">
        <button type="button" id="lesson-modal-cancel" class="px-3.5 py-2 hover:bg-muted text-xs font-bold rounded-lg border border-border transition-colors cursor-pointer text-muted-foreground hover:text-foreground">
          Cancel
        </button>
        <button type="submit" class="px-4 py-2 bg-primary text-primary-foreground hover:bg-primary/95 font-bold text-xs rounded-lg transition-colors cursor-pointer select-none">
          Save Lesson Details
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  import { PUBLIC_SERVER_URL } from "astro:env/client";
  import { toast } from "../../lib/dashboard-store";

  // Elements selectors
  const coursesListPanel = document.getElementById("courses-list-panel")!;
  const coursesGrid = document.getElementById("courses-grid")!;
  const coursesEmptyState = document.getElementById("courses-empty-state")!;
  const coursesEmptyCreateBtn = document.getElementById("courses-empty-create-btn")!;

  const coursesBuilderPanel = document.getElementById("courses-builder-panel")!;
  const builderBackBtn = document.getElementById("builder-back-btn")!;
  const builderCourseTitle = document.getElementById("builder-course-title")!;
  const builderCourseCategory = document.getElementById("builder-course-category")!;
  const builderCourseStatusBadge = document.getElementById("builder-course-status-badge")!;
  
  const builderCourseForm = document.getElementById("builder-course-form") as HTMLFormElement;
  const builderTitleInput = document.getElementById("builder-title-input") as HTMLInputElement;
  const builderSlugInput = document.getElementById("builder-slug-input") as HTMLInputElement;
  const builderSmallDescInput = document.getElementById("builder-smalldesc-input") as HTMLTextAreaElement;
  const builderPriceInput = document.getElementById("builder-price-input") as HTMLInputElement;
  const builderDurationInput = document.getElementById("builder-duration-input") as HTMLInputElement;
  const builderLevelInput = document.getElementById("builder-level-input") as HTMLSelectElement;
  const builderStatusInput = document.getElementById("builder-status-input") as HTMLSelectElement;
  const builderCategoryInput = document.getElementById("builder-category-input") as HTMLInputElement;
  
  const builderThumbFileInput = document.getElementById("builder-thumb-file-input") as HTMLInputElement;
  const builderThumbUploadBtn = document.getElementById("builder-thumb-upload-btn")!;
  const builderThumbPreview = document.getElementById("builder-thumb-preview")!;
  const builderThumbProgressContainer = document.getElementById("builder-thumb-progress-container")!;
  const builderThumbProgressBar = document.getElementById("builder-thumb-progress-bar")!;
  const builderThumbProgressText = document.getElementById("builder-thumb-progress-text")!;

  const builderChaptersContainer = document.getElementById("builder-chapters-container")!;
  const builderAddChapterBtn = document.getElementById("builder-add-chapter-btn")!;

  // Lesson Modal selectors
  const lessonModalOverlay = document.getElementById("lesson-modal-overlay")!;
  const lessonModalContent = document.getElementById("lesson-modal-content")!;
  const lessonModalClose = document.getElementById("lesson-modal-close")!;
  const lessonModalCancel = document.getElementById("lesson-modal-cancel")!;
  const lessonModalForm = document.getElementById("lesson-modal-form") as HTMLFormElement;
  const lessonTitleInput = document.getElementById("lesson-title-input") as HTMLInputElement;
  const lessonDescriptionInput = document.getElementById("lesson-description-input") as HTMLTextAreaElement;
  
  const lessonVideoFileInput = document.getElementById("lesson-video-file-input") as HTMLInputElement;
  const lessonVideoUploadBtn = document.getElementById("lesson-video-upload-btn")!;
  const lessonVideoStatus = document.getElementById("lesson-video-status")!;
  const lessonVideoProgressContainer = document.getElementById("lesson-video-progress-container")!;
  const lessonVideoProgressBar = document.getElementById("lesson-video-progress-bar")!;
  const lessonVideoProgressText = document.getElementById("lesson-video-progress-text")!;

  const lessonThumbFileInput = document.getElementById("lesson-thumb-file-input") as HTMLInputElement;
  const lessonThumbUploadBtn = document.getElementById("lesson-thumb-upload-btn")!;
  const lessonThumbPreview = document.getElementById("lesson-thumb-preview")!;
  const lessonThumbProgressContainer = document.getElementById("lesson-thumb-progress-container")!;
  const lessonThumbProgressBar = document.getElementById("lesson-thumb-progress-bar")!;
  const lessonThumbProgressText = document.getElementById("lesson-thumb-progress-text")!;

  // Local State
  let coursesList: any[] = [];
  let currentEditingCourse: any = null;
  let currentEditingLesson: any = null; // { lesson, chapterId }

  // Currency label selector
  const builderPriceLabel = document.getElementById("builder-price-label");

  // Helper to format currency dynamically based on preference
  function formatCurrency(priceInCents: number): string {
    const currency = localStorage.getItem("pref-currency") || "INR";
    const amount = priceInCents / 100;
    
    switch (currency) {
      case "USD":
        return amount.toLocaleString("en-US", { style: "currency", currency: "USD" });
      case "EUR":
        return amount.toLocaleString("en-IE", { style: "currency", currency: "EUR" });
      case "NPR":
        return amount.toLocaleString("en-NP", { style: "currency", currency: "NPR" });
      case "INR":
      default:
        return amount.toLocaleString("en-IN", { style: "currency", currency: "INR" });
    }
  }

  // Helper to dynamically update the price field label in the builder sidebar
  function updatePriceLabel() {
    if (builderPriceLabel) {
      const currency = localStorage.getItem("pref-currency") || "INR";
      builderPriceLabel.textContent = `Price (${currency})`;
    }
  }


  // ---------------------------------------------------------------------------
  // 1. API Interactions (Fetch Helpers)
  // ---------------------------------------------------------------------------

  // Load courses list
  async function loadCourses() {
    try {
      const res = await fetch(`${PUBLIC_SERVER_URL}/api/courses`, { credentials: "include" });
      if (!res.ok) throw new Error("Failed to load courses");
      
      coursesList = await res.json();
      renderCourses();
    } catch (e: any) {
      toast.error(e.message || "Failed to load courses Catalog");
    }
  }

  // Load a single course in detail (includes chapters & lessons)
  async function loadCourseDetail(courseId: string) {
    try {
      const res = await fetch(`${PUBLIC_SERVER_URL}/api/courses/${courseId}`, { credentials: "include" });
      if (!res.ok) throw new Error("Failed to load course details");
      
      currentEditingCourse = await res.json();
      openBuilderView();
    } catch (e: any) {
      toast.error(e.message || "Failed to load course builder");
    }
  }

  // Create course
  async function createCourse(title: string, category: string, description: string) {
    try {
      // Structure description as stringified JSON mock for Tiptap
      const emptyTiptapJson = JSON.stringify({
        type: "doc",
        content: [{ type: "paragraph", content: [{ type: "text", text: description }] }]
      });

      // Construct a slug from the title
      const slug = title
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/(^-|-$)/g, "");

      const res = await fetch(`${PUBLIC_SERVER_URL}/api/courses`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          title,
          slug,
          smallDescription: description.substring(0, 195) + "...",
          description: emptyTiptapJson,
          fileKey: "placeholder_thumbnail", // Initial placeholder
          price: 9900, // Default price $99.00 (in cents)
          duration: 10, // Default duration 10 hours
          level: "BEGINNER",
          category,
          status: "DRAFT"
        }),
        credentials: "include"
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || "Failed to create course");
      }

      toast.success("Course created successfully!");
      loadCourses();
      return true;
    } catch (e: any) {
      toast.error(e.message);
      return false;
    }
  }

  // Delete Course
  async function deleteCourse(courseId: string) {
    if (!confirm("Are you sure you want to delete this course? All chapters, lessons, and records will be deleted permanently!")) {
      return;
    }

    try {
      const res = await fetch(`${PUBLIC_SERVER_URL}/api/courses/${courseId}`, {
        method: "DELETE",
        credentials: "include"
      });

      if (!res.ok) throw new Error("Failed to delete course");

      toast.success("Course deleted successfully!");
      loadCourses();
    } catch (e: any) {
      toast.error(e.message);
    }
  }

  // S3 upload helper
  async function uploadFileToMinIO(file: File, onProgress: (pct: number) => void): Promise<string> {
    // 1. Get presigned URL
    const presignedRes = await fetch(`${PUBLIC_SERVER_URL}/api/uploads/presigned-url`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        filename: file.name,
        fileType: file.type,
        fileSize: file.size
      }),
      credentials: "include"
    });

    if (!presignedRes.ok) {
      const err = await presignedRes.json();
      throw new Error(err.error || "Failed to fetch presigned URL");
    }

    const { uploadUrl, fileKey } = await presignedRes.json();

    // 2. Perform direct PUT upload with progress reporting via XMLHttpRequest
    return new Promise((resolve, reject) => {
      const xhr = new XMLHttpRequest();
      xhr.open("PUT", uploadUrl, true);
      xhr.setRequestHeader("Content-Type", file.type);
      
      xhr.upload.onprogress = (event) => {
        if (event.lengthComputable) {
          const pct = Math.round((event.loaded / event.total) * 100);
          onProgress(pct);
        }
      };

      xhr.onload = () => {
        if (xhr.status === 200) {
          resolve(fileKey);
        } else {
          reject(new Error(`MinIO upload failed: ${xhr.statusText}`));
        }
      };

      xhr.onerror = () => reject(new Error("Network error during MinIO upload."));
      xhr.send(file);
    });
  }

  // ---------------------------------------------------------------------------
  // 2. Rendering Logic
  // ---------------------------------------------------------------------------

  // Render course list grid
  function renderCourses() {
    if (coursesList.length === 0) {
      coursesGrid.classList.add("hidden");
      coursesEmptyState.classList.remove("hidden");
      return;
    }

    coursesEmptyState.classList.add("hidden");
    coursesGrid.classList.remove("hidden");
    coursesGrid.innerHTML = "";

    coursesList.forEach((course) => {
      const card = document.createElement("div");
      card.className = "bg-card border border-border/50 rounded-lg overflow-hidden flex flex-col justify-between hover:shadow-lg hover:border-border/80 transition-all duration-300 group cursor-pointer";

      // Color Badge
      const levelColors: Record<string, string> = {
        BEGINNER: "bg-amber-400 text-amber-950 border-amber-500/20",
        INTERMEDIATE: "bg-emerald-500/10 text-emerald-500 border-emerald-500/20",
        ADVANCED: "bg-rose-500/10 text-rose-500 border-rose-500/20"
      };

      const statusColors: Record<string, string> = {
        DRAFT: "bg-muted text-muted-foreground border-border",
