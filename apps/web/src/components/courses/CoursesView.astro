  // ---------------------------------------------------------------------------
  // 3. View Switchers & Modals Control
  // ---------------------------------------------------------------------------

  function openBuilderView() {
    coursesListPanel.classList.add("hidden");
    coursesBuilderPanel.classList.remove("hidden");

    // Update currency label format
    updatePriceLabel();

    // Populate metadata inputs
    builderCourseTitle.textContent = currentEditingCourse.title;
    builderCourseCategory.textContent = currentEditingCourse.category;
    builderCourseStatusBadge.textContent = currentEditingCourse.status;
    
    // Status color badge class mapping
    builderCourseStatusBadge.className = "px-2 py-0.5 rounded-full text-[9px] font-bold border " + 
      (currentEditingCourse.status === "PUBLISHED" ? "bg-primary/15 text-primary border-primary/20" : "bg-muted text-muted-foreground border-border");

    builderTitleInput.value = currentEditingCourse.title;
    builderSlugInput.value = currentEditingCourse.slug;
    builderSmallDescInput.value = currentEditingCourse.smallDescription;
    builderPriceInput.value = (currentEditingCourse.price / 100).toString();
    builderDurationInput.value = currentEditingCourse.duration.toString();
    builderLevelInput.value = currentEditingCourse.level;
    builderStatusInput.value = currentEditingCourse.status;
    builderCategoryInput.value = currentEditingCourse.category;

    // Show thumbnail preview
    renderBuilderThumbPreview();

    // Render Chapters & Lessons
    renderCurriculum();
  }

  function renderBuilderThumbPreview() {
    if (currentEditingCourse.fileKey && currentEditingCourse.fileKey !== "placeholder_thumbnail") {
      builderThumbPreview.innerHTML = `
        <img src="${PUBLIC_SERVER_URL}/${currentEditingCourse.fileKey}" class="w-full h-full object-cover" />
      `;
    } else {
      builderThumbPreview.innerHTML = `<span class="text-[10px] text-muted-foreground">No thumbnail uploaded</span>`;
    }
  }

  function closeBuilderView() {
    coursesBuilderPanel.classList.add("hidden");
    coursesListPanel.classList.remove("hidden");
    currentEditingCourse = null;
    loadCourses();
  }

  // Lesson Modal Toggle
  function openLessonModal(lesson: any, chapterId: string) {
    currentEditingLesson = { lesson, chapterId };
    
    lessonTitleInput.value = lesson.title;
    lessonDescriptionInput.value = lesson.description || "";
    
    // Video status check
    if (lesson.videoKey) {
      lessonVideoStatus.textContent = "✓ Video Uploaded (" + lesson.videoKey.substring(0, 20) + "...)";
      lessonVideoStatus.className = "text-[10px] text-emerald-500 font-semibold text-center py-4 border border-emerald-500/20 rounded-md bg-emerald-500/5";
    } else {
      lessonVideoStatus.textContent = "No video uploaded";
      lessonVideoStatus.className = "text-[10px] text-muted-foreground text-center py-4 border border-dashed border-border rounded-md bg-muted/10";
    }

    // Thumbnail status check
    if (lesson.thumbnailKey) {
      lessonThumbPreview.innerHTML = `
        <img src="${PUBLIC_SERVER_URL}/${lesson.thumbnailKey}" class="w-full h-full object-cover" />
      `;
    } else {
      lessonThumbPreview.innerHTML = `<span class="text-[9px] text-muted-foreground">No thumbnail</span>`;
    }

    // Reset progress bars
    lessonVideoProgressContainer.classList.add("hidden");
    lessonThumbProgressContainer.classList.add("hidden");

    lessonModalOverlay.classList.remove("hidden");
    lessonModalOverlay.classList.add("flex");
    setTimeout(() => {
      lessonModalContent.classList.remove("scale-95", "opacity-0");
      lessonModalContent.classList.add("scale-100", "opacity-100");
    }, 50);
  }

  function closeLessonModal() {
    lessonModalContent.classList.remove("scale-100", "opacity-100");
    lessonModalContent.classList.add("scale-95", "opacity-0");
    setTimeout(() => {
      lessonModalOverlay.classList.remove("flex");
      lessonModalOverlay.classList.add("hidden");
      currentEditingLesson = null;
    }, 200);
  }

  // ---------------------------------------------------------------------------
  // 4. Form Submissions and Event Bindings
  // ---------------------------------------------------------------------------

  // Handle Course Meta Info Form Submission
  builderCourseForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!currentEditingCourse) return;

    try {
      const priceInCents = Math.round(parseFloat(builderPriceInput.value) * 100);

      const res = await fetch(`${PUBLIC_SERVER_URL}/api/courses/${currentEditingCourse.id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          title: builderTitleInput.value,
          slug: builderSlugInput.value,
          smallDescription: builderSmallDescInput.value,
          price: priceInCents,
          duration: parseInt(builderDurationInput.value),
          level: builderLevelInput.value,
          status: builderStatusInput.value,
          category: builderCategoryInput.value
        }),
        credentials: "include"
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || "Failed to update course properties");
      }

      toast.success("Course details saved!");
      currentEditingCourse = await res.json();
      
      // Update headers
      builderCourseTitle.textContent = currentEditingCourse.title;
      builderCourseCategory.textContent = currentEditingCourse.category;
      builderCourseStatusBadge.textContent = currentEditingCourse.status;
      builderCourseStatusBadge.className = "px-2 py-0.5 rounded-full text-[9px] font-bold border " + 
        (currentEditingCourse.status === "PUBLISHED" ? "bg-primary/15 text-primary border-primary/20" : "bg-muted text-muted-foreground border-border");

    } catch (e: any) {
      toast.error(e.message);
    }
  });

  // Handle Lesson details saving
  lessonModalForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!currentEditingCourse || !currentEditingLesson) return;

    const { lesson, chapterId } = currentEditingLesson;

    try {
      const res = await fetch(`${PUBLIC_SERVER_URL}/api/courses/${currentEditingCourse.id}/chapters/${chapterId}/lessons/${lesson.id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          title: lessonTitleInput.value,
          description: lessonDescriptionInput.value
        }),
        credentials: "include"
      });

      if (!res.ok) throw new Error("Failed to update lesson metadata");

      toast.success("Lesson details saved!");
      closeLessonModal();
      
      // Reload course structure
      loadCourseDetail(currentEditingCourse.id);
    } catch (e: any) {
      toast.error(e.message);
    }
  });

  // Wire event handlers to dynamic Curriculum elements
  function wireCurriculumListeners() {
    // 1. Chapter Actions
    document.querySelectorAll(".btn-chapter-edit").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const chapterId = btn.getAttribute("data-id")!;
        const currentTitle = btn.getAttribute("data-title")!;
        const newTitle = prompt("Enter new chapter title:", currentTitle);
        if (!newTitle || newTitle === currentTitle) return;

        try {
          const res = await fetch(`${PUBLIC_SERVER_URL}/api/courses/${currentEditingCourse.id}/chapters/${chapterId}`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ title: newTitle }),
            credentials: "include"
          });
          if (!res.ok) throw new Error("Failed to rename chapter");

          toast.success("Chapter renamed!");
          loadCourseDetail(currentEditingCourse.id);
        } catch (e: any) {
          toast.error(e.message);
        }
      });
    });

    document.querySelectorAll(".btn-chapter-delete").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const chapterId = btn.getAttribute("data-id")!;
        if (!confirm("Are you sure you want to delete this chapter? All lessons in it will be lost!")) return;

        try {
          const res = await fetch(`${PUBLIC_SERVER_URL}/api/courses/${currentEditingCourse.id}/chapters/${chapterId}`, {
            method: "DELETE",
            credentials: "include"
          });
          if (!res.ok) throw new Error("Failed to delete chapter");

          toast.success("Chapter deleted!");
          loadCourseDetail(currentEditingCourse.id);
        } catch (e: any) {
          toast.error(e.message);
        }
      });
    });

    // Chapter Reordering Up/Down
    document.querySelectorAll(".btn-chapter-up, .btn-chapter-down").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const chapterId = btn.getAttribute("data-id")!;
        const direction = btn.classList.contains("btn-chapter-up") ? "up" : "down";
        
        // Find indices
        const chapters = currentEditingCourse.chapters;
        const index = chapters.findIndex((c: any) => c.id === chapterId);
        if (index === -1) return;
        
        const targetIndex = direction === "up" ? index - 1 : index + 1;
        if (targetIndex < 0 || targetIndex >= chapters.length) return;

        // Perform swap positions locally first
        const payload = [
          { id: chapters[index].id, position: chapters[targetIndex].position },
          { id: chapters[targetIndex].id, position: chapters[index].position }
        ];

        try {
          const res = await fetch(`${PUBLIC_SERVER_URL}/api/reorder/chapters`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ chapters: payload }),
            credentials: "include"
          });
          if (!res.ok) throw new Error("Failed to reorder chapters");

          loadCourseDetail(currentEditingCourse.id);
        } catch (e: any) {
          toast.error(e.message);
        }
      });
    });

    // 2. Lesson Actions
    document.querySelectorAll(".btn-add-lesson").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const chapterId = btn.getAttribute("data-chapter-id")!;
        const title = prompt("Enter lesson title:");
        if (!title) return;

        try {
          const res = await fetch(`${PUBLIC_SERVER_URL}/api/courses/${currentEditingCourse.id}/chapters/${chapterId}/lessons`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ title }),
            credentials: "include"
          });
          if (!res.ok) throw new Error("Failed to create lesson");

          toast.success("Lesson created!");
          loadCourseDetail(currentEditingCourse.id);
        } catch (e: any) {
          toast.error(e.message);
        }
      });
    });

    document.querySelectorAll(".btn-lesson-edit").forEach((btn) => {
      btn.addEventListener("click", () => {
        const lessonId = btn.getAttribute("data-id")!;
        const chapterId = btn.getAttribute("data-chapter-id")!;
        
        // Find chapter
        const chapter = currentEditingCourse.chapters.find((c: any) => c.id === chapterId);
        if (!chapter) return;
        const lesson = chapter.lessons.find((l: any) => l.id === lessonId);
        if (!lesson) return;

        openLessonModal(lesson, chapterId);
      });
    });

    document.querySelectorAll(".btn-lesson-delete").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const lessonId = btn.getAttribute("data-id")!;
        const chapterId = btn.getAttribute("data-chapter-id")!;
        if (!confirm("Are you sure you want to delete this lesson?")) return;

        try {
          const res = await fetch(`${PUBLIC_SERVER_URL}/api/courses/${currentEditingCourse.id}/chapters/${chapterId}/lessons/${lessonId}`, {
            method: "DELETE",
            credentials: "include"
          });
          if (!res.ok) throw new Error("Failed to delete lesson");

          toast.success("Lesson deleted!");
          loadCourseDetail(currentEditingCourse.id);
        } catch (e: any) {
          toast.error(e.message);
        }
      });
    });

    // Lesson Reordering Up/Down
    document.querySelectorAll(".btn-lesson-up, .btn-lesson-down").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const lessonId = btn.getAttribute("data-id")!;
        const chapterId = btn.getAttribute("data-chapter-id")!;
        const direction = btn.classList.contains("btn-lesson-up") ? "up" : "down";

        // Find chapter
        const chapter = currentEditingCourse.chapters.find((c: any) => c.id === chapterId);
        if (!chapter) return;
        
        // Find indices
        const lessons = chapter.lessons;
        const index = lessons.findIndex((l: any) => l.id === lessonId);
        if (index === -1) return;

        const targetIndex = direction === "up" ? index - 1 : index + 1;
        if (targetIndex < 0 || targetIndex >= lessons.length) return;

        // Swapping payload
        const payload = [
          { id: lessons[index].id, position: lessons[targetIndex].position },
          { id: lessons[targetIndex].id, position: lessons[index].position }
        ];

        try {
          const res = await fetch(`${PUBLIC_SERVER_URL}/api/reorder/lessons`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ lessons: payload }),
            credentials: "include"
          });
          if (!res.ok) throw new Error("Failed to reorder lessons");

          loadCourseDetail(currentEditingCourse.id);
        } catch (e: any) {
          toast.error(e.message);
        }
      });
    });
  }

  // ---------------------------------------------------------------------------
  // 5. File Upload Listeners
  // ---------------------------------------------------------------------------

  // A. Course Thumbnail Upload
  builderThumbUploadBtn.addEventListener("click", () => builderThumbFileInput.click());
  
  builderThumbFileInput.addEventListener("change", async () => {
    if (!builderThumbFileInput.files || builderThumbFileInput.files.length === 0 || !currentEditingCourse) return;

    const file = builderThumbFileInput.files[0];
    builderThumbProgressContainer.classList.remove("hidden");

    try {
      const fileKey = await uploadFileToMinIO(file, (pct) => {
        builderThumbProgressBar.style.width = pct + "%";
        builderThumbProgressText.textContent = pct + "%";
      });

      // Update course thumbnail reference in DB
      const res = await fetch(`${PUBLIC_SERVER_URL}/api/courses/${currentEditingCourse.id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ fileKey }),
        credentials: "include"
      });

      if (!res.ok) throw new Error("Failed to update course thumbnail Key in DB");

      toast.success("Thumbnail uploaded successfully!");
      currentEditingCourse = await res.json();
      renderBuilderThumbPreview();
    } catch (e: any) {
      toast.error(e.message || "Failed to upload thumbnail");
    } finally {
      builderThumbProgressContainer.classList.add("hidden");
      builderThumbFileInput.value = "";
    }
  });

  // B. Lesson Video Upload
  lessonVideoUploadBtn.addEventListener("click", () => lessonVideoFileInput.click());

  lessonVideoFileInput.addEventListener("change", async () => {
    if (!lessonVideoFileInput.files || lessonVideoFileInput.files.length === 0 || !currentEditingCourse || !currentEditingLesson) return;

    const file = lessonVideoFileInput.files[0];
    lessonVideoProgressContainer.classList.remove("hidden");

    try {
      const videoKey = await uploadFileToMinIO(file, (pct) => {
        lessonVideoProgressBar.style.width = pct + "%";
        lessonVideoProgressText.textContent = pct + "%";
      });

      // Save video reference in DB
      const { lesson, chapterId } = currentEditingLesson;
      const res = await fetch(`${PUBLIC_SERVER_URL}/api/courses/${currentEditingCourse.id}/chapters/${chapterId}/lessons/${lesson.id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ videoKey }),
        credentials: "include"
      });

      if (!res.ok) throw new Error("Failed to save video reference in database");

      toast.success("Video uploaded successfully!");
      
      // Update state locally
      const updatedLesson = await res.json();
      currentEditingLesson.lesson = updatedLesson;

      // Update UI
      lessonVideoStatus.textContent = "✓ Video Uploaded (" + videoKey.substring(0, 20) + "...)";
      lessonVideoStatus.className = "text-[10px] text-emerald-500 font-semibold text-center py-4 border border-emerald-500/20 rounded-md bg-emerald-500/5";

    } catch (e: any) {
      toast.error(e.message || "Failed to upload video");
    } finally {
      lessonVideoProgressContainer.classList.add("hidden");
      lessonVideoFileInput.value = "";
    }
  });

  // C. Lesson Thumbnail Upload
  lessonThumbUploadBtn.addEventListener("click", () => lessonThumbFileInput.click());

  lessonThumbFileInput.addEventListener("change", async () => {
    if (!lessonThumbFileInput.files || lessonThumbFileInput.files.length === 0 || !currentEditingCourse || !currentEditingLesson) return;

    const file = lessonThumbFileInput.files[0];
    lessonThumbProgressContainer.classList.remove("hidden");

    try {
      const thumbnailKey = await uploadFileToMinIO(file, (pct) => {
        lessonThumbProgressBar.style.width = pct + "%";
        lessonThumbProgressText.textContent = pct + "%";
      });

      // Save thumbnail reference in DB
      const { lesson, chapterId } = currentEditingLesson;
      const res = await fetch(`${PUBLIC_SERVER_URL}/api/courses/${currentEditingCourse.id}/chapters/${chapterId}/lessons/${lesson.id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ thumbnailKey }),
        credentials: "include"
      });

      if (!res.ok) throw new Error("Failed to save thumbnail reference in database");

      toast.success("Lesson thumbnail uploaded!");
      
      const updatedLesson = await res.json();
      currentEditingLesson.lesson = updatedLesson;

      // Update UI preview
      lessonThumbPreview.innerHTML = `
        <img src="${PUBLIC_SERVER_URL}/${thumbnailKey}" class="w-full h-full object-cover" />
      `;

    } catch (e: any) {
      toast.error(e.message || "Failed to upload image");
    } finally {
      lessonThumbProgressContainer.classList.add("hidden");
      lessonThumbFileInput.value = "";
    }
  });

  // ---------------------------------------------------------------------------
  // 6. Global Initializations
  // ---------------------------------------------------------------------------

  // Wire buttons inside panel

  coursesEmptyCreateBtn.addEventListener("click", () => {
    const trigger = document.getElementById("create-course-btn");
    if (trigger) trigger.click();
  });

  builderBackBtn.addEventListener("click", closeBuilderView);

  builderAddChapterBtn.addEventListener("click", async () => {
    if (!currentEditingCourse) return;
    const title = prompt("Enter chapter title:");
    if (!title) return;

    try {
      const res = await fetch(`${PUBLIC_SERVER_URL}/api/courses/${currentEditingCourse.id}/chapters`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ title }),
        credentials: "include"
      });
      if (!res.ok) throw new Error("Failed to create chapter");

      toast.success("Chapter added!");
      loadCourseDetail(currentEditingCourse.id);
    } catch (e: any) {
      toast.error(e.message);
    }
  });

  // Lesson Modal close bindings
  lessonModalClose.addEventListener("click", closeLessonModal);
  lessonModalCancel.addEventListener("click", closeLessonModal);
  lessonModalOverlay.addEventListener("click", (e) => {
    if (e.target === lessonModalOverlay) closeLessonModal();
  });

  // Listen to navigation trigger and custom event from header/modal
  document.addEventListener("courses-updated", () => {
    loadCourses();
  });

  // Listen to preferences updates to refresh pricing currency dynamically
  document.addEventListener("preferences-updated", () => {
    loadCourses();
    updatePriceLabel();
  });

  // Intercept HiverLMS Sidebar active selection or manual loading
  const navCoursesBtn = document.getElementById("nav-courses");
  if (navCoursesBtn) {
    navCoursesBtn.addEventListener("click", () => {
      loadCourses();
    });
  }

  // Load catalog on start if active
  const activeNavItem = localStorage.getItem("active-nav-item");
  if (activeNavItem === "nav-courses") {
    loadCourses();
  }
</script>
