{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.mjs"
	},
	"dependencies": {
		"@hivertradercourse/auth": "*",
		"@hivertradercourse/db": "*",
		"@hivertradercourse/env": "*",
		"@hono/node-server": "^1.14.4",
		"ably": "^2.22.1",
		"better-auth": "1.6.11",
		"dotenv": "^17.2.2",
		"hono": "^4.8.2",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@hivertradercourse/config": "*",
		"@types/node": "^22.13.14",
		"tsdown": "^0.21.9",
		"tsx": "^4.19.2",
		"typescript": "^6"
	}
}
